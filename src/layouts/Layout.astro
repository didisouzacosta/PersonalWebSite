---
import '../styles/global.css'
import Analytics from '../components/Analytics.astro';
import CookieConsentBanner from '../components/CookieConsentBanner.astro';
import Controls from '../components/Controls.astro';
import { createAnalyticsPageContext } from '../core/analyticsContext';
import { absoluteUrl, defaultOgImage, normalizePath, siteUrl, type AlternateLocale, type JsonLdValue } from '../core/seo';

interface Props {
    title: string,
    description?: string,
    ogImage?: string,
    favicon?: string,
    lang?: string,
    metas?: { name: string, content: string }[],
    canonicalPath?: string,
    canonicalUrl?: string,
    alternateLocales?: AlternateLocale[],
    jsonLd?: JsonLdValue,
    ogType?: string,
    robots?: string,
}

const {
    title,
    description,
    ogImage = defaultOgImage,
    favicon,
    lang = 'en',
    metas = [],
    canonicalPath,
    canonicalUrl,
    alternateLocales = [],
    jsonLd,
    ogType = 'website',
    robots = 'index, follow',
} = Astro.props;

const documentLang = lang === 'pt-br' ? 'pt-BR' : lang;
const currentPath = normalizePath(Astro.url.pathname);
const canonical = canonicalUrl ?? absoluteUrl(canonicalPath ?? currentPath);
const analyticsContext = createAnalyticsPageContext({
    path: currentPath,
    canonical,
    title,
    lang,
});
const absoluteOgImage = absoluteUrl(ogImage);
const ogLocale = documentLang === 'pt-BR' ? 'pt_BR' : 'en_US';
const alternateOgLocales = alternateLocales
    .filter((alternate) => alternate.lang !== 'x-default' && alternate.lang !== documentLang)
    .map((alternate) => alternate.lang === 'pt-BR' ? 'pt_BR' : 'en_US');
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const isPtBr = lang === 'pt-br';
const navigationItems = [
    { label: 'Home', href: isPtBr ? '/pt-br/' : '/', match: isPtBr ? '/pt-br/' : '/' },
    { label: 'Apps', href: isPtBr ? '/pt-br/#apps' : '/#apps', match: isPtBr ? '/pt-br/apps/' : '/apps/' },
    { label: 'Resume', href: isPtBr ? '/resume/pt-br/' : '/resume/', match: isPtBr ? '/resume/pt-br/' : '/resume/' },
];
const isActiveNavigationItem = (match: string) => {
    if (match === '/') {
        return currentPath === '/';
    }

    if (match === '/pt-br/') {
        return currentPath === '/pt-br/';
    }

    return currentPath.startsWith(match);
};
const footerText = isPtBr
    ? 'Desenvolvido por Adriano Souza Costa.'
    : 'Built by Adriano Souza Costa.';
const footerLinks = [
    { label: 'GitHub', href: 'https://github.com/didisouzacosta' },
    { label: 'LinkedIn', href: 'https://www.linkedin.com/in/adrianosouzacosta' },
    { label: 'X', href: 'https://x.com/didisouzacosta' },
];
const privacySettingsLabel = isPtBr ? 'Preferências de privacidade' : 'Privacy settings';
---

<!doctype html>
<html lang={documentLang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

        <!-- Theme init (must be before CSS to avoid FOUC) -->
        <script is:inline>
            (function() {
                var saved = localStorage.getItem('theme');
                var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                document.documentElement.setAttribute('data-theme', saved || (prefersDark ? 'dark' : 'light'));
            })();
        </script>

        <link rel="icon" type="image/png" href={`https://pub-81dc0daed73f4a358469301b9b80f493.r2.dev/favicon/${favicon ?? "favicon-32x32.png"}`} />
        <meta name="generator" content={Astro.generator} />
        <meta name="robots" content={robots}>
        <link rel="canonical" href={canonical}>
        {description && <meta name="description" content={description}>}
        {
            alternateLocales.map((alternate) => (
                <link rel="alternate" hreflang={alternate.lang} href={absoluteUrl(alternate.path)} />
            ))
        }

        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonical} />
        <meta property="og:title" content={title} />
        {description && <meta property="og:description" content={description} />}
        <meta property="og:image" content={absoluteOgImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:locale" content={ogLocale} />
        {alternateOgLocales.map((locale) => <meta property="og:locale:alternate" content={locale} />)}
        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        {description && <meta name="twitter:description" content={description} />}
        <meta name="twitter:image" content={absoluteOgImage} />

        {
            metas.map((meta) => <meta name={meta.name} content={meta.content}>)
        }

        <title>{title}</title>

        {
            jsonLdItems.map((item) => (
                <script type="application/ld+json" set:html={JSON.stringify(item)} />
            ))
        }

        <Analytics context={analyticsContext} />
    </head>
    <body>
        <header class="site-header">
            <div class="site-header-inner">
                <nav class="site-menu" aria-label={isPtBr ? 'Navegação principal' : 'Primary navigation'}>
                    {
                        navigationItems.map((item) => (
                            <a
                                href={item.href}
                                aria-current={isActiveNavigationItem(item.match) ? 'page' : undefined}
                                data-analytics-event="navigation_clicked"
                                data-analytics-location="site-header"
                                data-analytics-label={item.label}
                            >
                                {item.label}
                            </a>
                        ))
                    }
                </nav>
                <Controls lang={lang} currentPath={Astro.url.pathname} />
            </div>
        </header>
        <slot />
        <footer class="site-footer">
            <div class="site-footer-inner">
                <p>
                    <a
                        href={siteUrl}
                        class="footer-credit"
                        data-preserve-host
                    >
                        {footerText}
                    </a>
                </p>
                <nav class="site-footer-actions" aria-label={isPtBr ? 'Links sociais' : 'Social links'}>
                    {
                        footerLinks.map((link) => (
                            <a
                                href={link.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                data-analytics-event="social_link_clicked"
                                data-analytics-location="site-footer"
                                data-analytics-label={link.label}
                            >
                                {link.label}
                            </a>
                        ))
                    }
                    <button
                        type="button"
                        class="privacy-settings"
                        data-analytics-ignore="true"
                        data-consent-open
                        onclick="document.getElementById('cookie-consent')?.removeAttribute('hidden')"
                    >
                        {privacySettingsLabel}
                    </button>
                </nav>
            </div>
        </footer>
        <CookieConsentBanner lang={lang} />
        <script is:inline>
            var observer = new IntersectionObserver(
                function(entries) {
                    entries.forEach(function(e) {
                        if (e.isIntersecting) {
                            e.target.classList.add('visible');
                            observer.unobserve(e.target);
                        }
                    });
                },
                { threshold: 0.15 }
            );
            document.querySelectorAll('.fade-in').forEach(function(el) { observer.observe(el); });
        </script>
        <style>
            .site-header {
                position: fixed;
                top: calc(20px + var(--safe-area-top));
                left: 0;
                right: 0;
                z-index: 100;
                pointer-events: none;
            }

            .site-header-inner {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 16px;
                max-width: 980px;
                margin: 0 auto;
                padding-right: calc(32px + var(--safe-area-right));
                padding-left: calc(32px + var(--safe-area-left));
            }

            .site-menu {
                display: flex;
                align-items: center;
                gap: 2px;
                max-width: 100%;
                padding: 4px;
                overflow-x: auto;
                border-radius: 980px;
                background-color: color-mix(in srgb, var(--bg) 78%, transparent);
                box-shadow: 0 8px 28px rgba(0, 0, 0, 0.06);
                backdrop-filter: blur(18px);
                -webkit-backdrop-filter: blur(18px);
                pointer-events: auto;
                scrollbar-width: none;
            }

            .site-header :global(.controls) {
                pointer-events: auto;
            }

            .site-menu::-webkit-scrollbar {
                display: none;
            }

            .site-menu a {
                flex: 0 0 auto;
                padding: 7px 12px;
                border-radius: 980px;
                color: var(--text-secondary);
                font-size: 13px;
                font-weight: 600;
                line-height: 1;
                transition: background-color 0.2s ease-out, color 0.2s ease-out, opacity 0.2s ease-out;
            }

            .site-menu a:hover,
            .site-menu a[aria-current="page"] {
                color: var(--text-primary);
                background-color: var(--bg-secondary);
                opacity: 1;
            }

            .site-footer {
                padding: 32px 0;
                color: var(--text-tertiary);
            }

            .site-footer-inner {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 18px;
                max-width: 980px;
                margin: 0 auto;
                padding-right: var(--safe-page-padding-right);
                padding-left: var(--safe-page-padding-left);
            }

            .site-footer p,
            .site-footer a,
            .site-footer button {
                font-size: 14px;
                line-height: 1.4;
            }

            .site-footer nav {
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .site-footer a,
            .site-footer button {
                color: var(--text-secondary);
            }

            .site-footer .footer-credit {
                color: var(--text-tertiary);
            }

            .site-footer a:hover,
            .site-footer button:hover {
                color: var(--text-primary);
                opacity: 1;
            }

            .site-footer button {
                padding: 0;
                border: 0;
                background: none;
                font: inherit;
                cursor: pointer;
            }

            .site-footer .privacy-settings {
                margin-left: 2px;
                padding-left: 16px;
                border-left: 1px solid var(--border);
            }

            @media (max-width: 760px) {
                .site-header {
                    top: calc(14px + var(--safe-area-top));
                }

                .site-header-inner {
                    gap: 10px;
                    padding-right: calc(16px + var(--safe-area-right));
                    padding-left: calc(16px + var(--safe-area-left));
                }

                .site-menu {
                    min-width: 0;
                }

                .site-menu a {
                    padding: 7px 10px;
                    font-size: 12px;
                }

                .site-header :global(.controls) {
                    gap: 6px;
                }

                .site-header :global(.ctrl-btn) {
                    width: 34px;
                    height: 34px;
                    font-size: 12px;
                }

                .site-footer-inner {
                    align-items: flex-start;
                    flex-direction: column;
                    padding-right: var(--safe-page-padding-right);
                    padding-left: var(--safe-page-padding-left);
                }

                .site-footer nav {
                    flex-wrap: wrap;
                    gap: 12px 16px;
                }

                .site-footer .privacy-settings {
                    width: 100%;
                    margin-left: 0;
                    padding-left: 0;
                    border-left: 0;
                    text-align: left;
                }
            }
        </style>
    </body>
</html>

---
import AppTemplate from "../../../../components/app/AppTemplate.astro";

const title = "DuoTake";
const pageTitle = "DuoTake | App de Câmera Dupla para Reacts";
const description =
    "DuoTake é um app de câmera dupla para iPhone que grava reacts com as câmeras frontal e traseira ao mesmo tempo, com CropOut para enquadramento mais limpo.";
const favicon = "favicon-duotake-32x32.png";
const appIcon = "duotake/app-icon.png";

const metas = [];
const primaryKeyword = "app de câmera dupla";
const secondaryKeywords = ["app para reacts", "câmera frontal e traseira", "app de câmera para iPhone"];

const screenshots = [
    {
        url: "duotake/screenshots/frame-1.png",
        alt: "Captura de câmera dupla do DuoTake em retrato e paisagem ao mesmo tempo.",
        caption: "Capture a cena e sua reação em uma única tomada.",
    },
    {
        url: "duotake/screenshots/frame-2.png",
        alt: "Seleção de modo do DuoTake para gravação em dois formatos.",
        caption: "Escolha o modo de gravação ideal para a plataforma do seu conteúdo.",
    },
    {
        url: "duotake/screenshots/frame-3.png",
        alt: "Tela de configurações de câmera do DuoTake antes da captura dupla.",
        caption: "Ajuste a câmera antes de cada foto ou vídeo.",
    },
    {
        url: "duotake/screenshots/frame-4.png",
        alt: "Opções de foto e vídeo do DuoTake para redes sociais.",
        caption: "Faça fotos e vídeos prontos para posts no estilo react.",
    },
];

const facts = [
    { label: "Plataforma", value: "iPhone" },
    { label: "Ideal para", value: "Vídeos de react" },
    { label: "Captura", value: "Câmeras frontal + traseira" },
];

const features = [
    {
        title: "Captura com duas câmeras",
        description: "Grave a cena e sua reação ao mesmo tempo usando as câmeras frontal e traseira.",
    },
    {
        title: "Enquadramento com CropOut",
        description: "Crie um enquadramento mais limpo para reacts sem refazer sua configuração a cada tomada.",
    },
    {
        title: "Modos de foto e vídeo",
        description: "Capture imagens ou vídeos conforme o formato que você precisa publicar.",
    },
];

const useCases = [
    {
        title: "Criadores de reacts",
        description: "Mostre o que você está assistindo e sua reação em uma captura pronta para compartilhar.",
    },
    {
        title: "Bastidores e comentários",
        description: "Grave o momento e a pessoa por trás da câmera sem alternar entre apps.",
    },
];

const faq = [
    {
        question: "O que é DuoTake?",
        answer: "DuoTake é um app de câmera criado para capturar com a câmera frontal e traseira ao mesmo tempo, tanto em foto quanto em vídeo. Ele também inclui o <strong>CropOut</strong>, que ajuda a criar um enquadramento ideal para reacts e conteúdos de reação.",
    },
    {
        question: "Para quem o DuoTake foi feito?",
        answer: "O DuoTake é ideal para criadores, social media, vloggers e qualquer pessoa que produz reacts, comentários ou bastidores e quer mostrar ao mesmo tempo a cena e a própria reação.",
    },
    {
        question: "Posso tirar fotos e gravar vídeos?",
        answer: "Sim. O DuoTake suporta fotos e vídeos usando simultaneamente a câmera frontal e a traseira, facilitando capturar sua reação e o que você está vendo em uma única tomada.",
    },
    {
        question: "O DuoTake funciona offline?",
        answer: "Sim. A captura principal e o processamento de mídia foram pensados para funcionar diretamente no seu dispositivo. Recursos que dependem de serviços da Apple, como validação de compra ou salvamento na fototeca, podem exigir as permissões do sistema.",
    },
    {
        question: "Como restaurar minha compra?",
        answer: "Se você já desbloqueou os recursos premium do DuoTake, toque em <em>Restaurar Compras</em> e o app pedirá à Apple para validar sua compra anterior com o mesmo Apple ID — sem custo extra.",
    },
];
---

<AppTemplate
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="pt-br"
    applicationCategory="MultimediaApplication"
/>

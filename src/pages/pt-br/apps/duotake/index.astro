---
import AppTemplate from "../../../../components/app/AppTemplate.astro";

const title = "DuoTake: Câmera dupla";
const appName = "DuoTake";
const pageTitle = "DuoTake: Câmera dupla";
const description =
    "Grave com a câmera frontal e traseira ao mesmo tempo. Capture o momento e sua reação, sem cortes, pronto para TikTok, Reels e Shorts.";
const favicon = "favicon-duotake-32x32.png";
const appIcon = "duotake/app-icon.png";

const metas = [];
const primaryKeyword = "câmera dupla";
const secondaryKeywords = [
    "react video",
    "editor video",
    "frontal traseira",
    "criador conteudo",
    "gravar video",
    "TikTok Reels Shorts",
];

const screenshots = [
    {
        url: {
            en: "duotake/screenshots/en/frame-1.png",
            ptBr: "duotake/screenshots/ptBR/frame-1.png",
        },
        alt: "Exemplos do DuoTake mostrando gravação com câmera frontal e traseira ao mesmo tempo.",
        caption: "Capture as câmeras frontal e traseira juntas no layout ideal para o momento.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-2.png",
            ptBr: "duotake/screenshots/ptBR/frame-2.png",
        },
        alt: "Tela de gravação do DuoTake em um estádio com janela de reação sobre a câmera traseira.",
        caption: "Mantenha a cena e sua reação juntas em uma única gravação.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-3.png",
            ptBr: "duotake/screenshots/ptBR/frame-3.png",
        },
        alt: "Prévia de recorte automático do DuoTake mantendo a pessoa bem enquadrada sobre o fundo.",
        caption: "Use o recorte automático para deixar os reacts mais limpos e focados.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-4.png",
            ptBr: "duotake/screenshots/ptBR/frame-4.png",
        },
        alt: "Layouts de câmera dupla do DuoTake com exemplos de gravação em aquário e ao ar livre com pet.",
        caption: "Mostre o momento e sua expressão por dois ângulos ao mesmo tempo.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-5.png",
            ptBr: "duotake/screenshots/ptBR/frame-5.png",
        },
        alt: "Tela de presets do editor do DuoTake com formatos social, quadrado, retrato e paisagem.",
        caption: "Escolha formatos prontos para Reels, TikTok, Shorts e outros canais.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-6.png",
            ptBr: "duotake/screenshots/ptBR/frame-6.png",
        },
        alt: "Tela de exportação do DuoTake com opções de qualidade para o vídeo final.",
        caption: "Exporte vídeos finalizados em alta qualidade, até a resolução original.",
    },
];

const facts = [
    { label: "Plataforma", value: "iPhone" },
    { label: "Ideal para", value: "Creators, reviews e reacts" },
    { label: "Pronto para", value: "TikTok, Reels e Shorts" },
];

const features = [
    {
        title: "Gravação com duas câmeras",
        description: "Use a câmera frontal e traseira ao mesmo tempo para manter a história e sua reação no mesmo vídeo.",
    },
    {
        title: "Reações em tempo real",
        description: "Capture o que está acontecendo e como você reage em um único vídeo, sem cortes entre clipes.",
    },
    {
        title: "Remoção de fundo",
        description: "Deixe o foco em você com remoção de fundo para vídeos de react mais limpos.",
    },
    {
        title: "Dois ângulos em um vídeo",
        description: "Mostre o momento por uma câmera e sua expressão pela outra em uma tomada pronta para compartilhar.",
    },
    {
        title: "Pronto para redes sociais",
        description: "Prepare vídeos para TikTok, Instagram Reels, YouTube Shorts e outros canais de creators.",
    },
    {
        title: "Exportação em alta qualidade",
        description: "Exporte vídeos finalizados em alta qualidade, prontos para publicar sem etapas extras de edição.",
    },
];

const useCases = [
    {
        title: "Registre tudo. Inclusive sua reação.",
        description: "Com o DuoTake, você grava usando a câmera frontal e traseira ao mesmo tempo, mostrando o que está acontecendo e como você reage em um único vídeo.",
    },
    {
        title: "Mostre tudo",
        description: "Pare de gravar só metade da história. Capture o momento, seu ponto de vista e sua reação juntos.",
    },
];

const faq = [
    {
        question: "O que é DuoTake?",
        answer: "DuoTake é um app de câmera dupla para gravar com a câmera frontal e traseira ao mesmo tempo. Ele ajuda você a capturar o momento e sua reação em um único vídeo, sem cortes entre clipes.",
    },
    {
        question: "Para quem o DuoTake foi feito?",
        answer: "O DuoTake é perfeito para creators, reviews, reacts, comentários, bastidores e qualquer pessoa que quer mostrar o que está acontecendo e como reage ao mesmo tempo.",
    },
    {
        question: "O DuoTake é pronto para TikTok, Reels e Shorts?",
        answer: "Sim. O DuoTake inclui formatos prontos para redes sociais, ajudando você a preparar vídeos para TikTok, Instagram Reels, YouTube Shorts e outros canais.",
    },
    {
        question: "O DuoTake tem remoção de fundo?",
        answer: "Sim. O DuoTake inclui remoção de fundo para deixar sua reação mais limpa, focada e fácil de combinar com o momento que você está gravando.",
    },
    {
        question: "O DuoTake funciona offline?",
        answer: "Sim. A captura principal e o processamento de mídia foram pensados para funcionar diretamente no seu dispositivo. Recursos que dependem de serviços da Apple, como validação de compra ou salvamento na fototeca, podem exigir as permissões do sistema.",
    },
    {
        question: "Como restaurar minha compra?",
        answer: "Se você já desbloqueou os recursos premium do DuoTake, toque em <em>Restaurar Compras</em> e o app pedirá à Apple para validar sua compra anterior com o mesmo Apple ID — sem custo extra.",
    },
];
---

<AppTemplate
    title={title}
    appName={appName}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="pt-br"
    applicationCategory="MultimediaApplication"
/>

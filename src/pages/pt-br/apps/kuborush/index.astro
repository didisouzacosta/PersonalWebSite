---
import AppTemplate from "../../../../components/app/AppTemplate.astro";

const appId = "id6757385646";
const title = "KuboRush - Quebra-Cabeça de Blocos";
const pageTitle = "KuboRush | Jogo de Quebra-Cabeça de Blocos para iOS";
const description =
    "KuboRush é um jogo inteligente e relaxante de quebra-cabeça de blocos para pausas rápidas de 2 minutos. Encaixe peças, pense com estratégia e limpe o tabuleiro no seu ritmo.";
const favicon = "apps/kuborush/favicon.png";
const appIcon = "kuborush/app-icon.png";
const socialImage = "/social/apps/kuborush-share-pt-br.jpg";
const socialImageAlt = "Ícone do app KuboRush com resumo do jogo de blocos.";

const metas = [{ name: "apple-itunes-app", content: `app-id=6757385646` }];
const primaryKeyword = "puzzle";
const secondaryKeywords = [
    "relaxar",
    "rápido",
    "blocos",
    "cubo",
    "desafio",
    "lógica",
    "tabuleiro",
    "competitivo",
    "passatempo",
    "cérebro",
    "casual",
];

const screenshots = [
    {
        url: {
            en: "kuborush/screenshots/en/frame-1.png",
            ptBr: "kuborush/screenshots/ptBR/frame-1.png",
        },
        alt: "Tela inicial do KuboRush apresentando pausas rápidas e relaxantes de puzzle de blocos.",
        caption: "Abra o KuboRush sempre que quiser uma pausa inteligente de 2 minutos.",
    },
    {
        url: {
            en: "kuborush/screenshots/en/frame-2.png",
            ptBr: "kuborush/screenshots/ptBR/frame-2.png",
        },
        alt: "Tabuleiro do KuboRush com peças prontas para encaixar, girar, embaralhar ou resolver com dica.",
        caption: "Encaixe peças com estratégia e use Dica, Embaralhar ou Girar quando precisar de controle.",
    },
    {
        url: {
            en: "kuborush/screenshots/en/frame-3.png",
            ptBr: "kuborush/screenshots/ptBR/frame-3.png",
        },
        alt: "Jogabilidade do KuboRush com blocos limpos, estratégia de tabuleiro e jogadas com desfazer.",
        caption: "Limpe o tabuleiro no seu ritmo e desfaça até seus 3 últimos movimentos quando mudar de ideia.",
    },
    {
        url: {
            en: "kuborush/screenshots/en/frame-4.png",
            ptBr: "kuborush/screenshots/ptBR/frame-4.png",
        },
        alt: "Telas competitivas do KuboRush com rankings do Hall da Fama e eventos Rush Semanal.",
        caption: "Mostre suas habilidades no Hall da Fama ou participe do evento Rush Semanal.",
    },
];

const facts = [
    { label: "Plataforma", value: "iOS" },
    { label: "Pausas", value: "Sessões de 2 minutos" },
    { label: "Estilo", value: "Estratégia relaxante" },
    { label: "Competição", value: "Hall da Fama + Rush Semanal" },
];

const features = [
    {
        title: "Controle total das jogadas",
        description: "Travou? Use Dica para a melhor jogada, Embaralhar para novas peças ou Girar para o encaixe perfeito.",
    },
    {
        title: "Jogue sem medo",
        description: "Errou? Desfazer permite reverter até seus 3 últimos movimentos para você continuar experimentando.",
    },
    {
        title: "Competição amigável",
        description: "Mostre suas habilidades com amigos no Hall da Fama ou participe do evento Rush Semanal.",
    },
];

const useCases = [
    {
        title: "Pausas rápidas",
        description: "Transforme pausas curtas em momentos de puzzle inteligentes e relaxantes para recarregar a mente.",
    },
    {
        title: "Estratégia tranquila",
        description: "Encaixe peças, planeje à frente e limpe o tabuleiro no seu próprio ritmo, sem estresse.",
    },
];

const faq = [
    {
        question: "O que é KuboRush?",
        answer: "KuboRush é um jogo inteligente e relaxante de quebra-cabeça de blocos feito para pausas rápidas de 2 minutos. Encaixe peças, pense com estratégia e limpe o tabuleiro no seu ritmo.",
    },
    {
        question: "Quais power-ups estão disponíveis?",
        answer: "KuboRush dá controle total das jogadas: <strong>Dica</strong> mostra a melhor jogada quando você está travado, <strong>Embaralhar</strong> traz novas peças, <strong>Girar</strong> ajuda a encontrar o encaixe perfeito e <strong>Desfazer</strong> reverte até seus 3 últimos movimentos.",
    },
    {
        question: "Quais são os modos competitivos?",
        answer: "Existem dois modos competitivos: <strong>Hall da Fama</strong>, onde você compete com amigos em rankings globais, e <strong>Rush Semanal</strong>, um evento semanal com desafios especiais para testar suas habilidades.",
    },
    {
        question: "KuboRush é gratuito?",
        answer: "Sim, KuboRush é gratuito para baixar e jogar. O upgrade <strong>KuboRush Pro</strong> está disponível como compra única no app, desbloqueando recursos adicionais.",
    },
    {
        question: "Como restaurar minha compra?",
        answer: "Se você já adquiriu o KuboRush Pro, não precisa pagar novamente ao trocar de dispositivo ou reinstalar o app. Basta tocar no botão <em>Restaurar Compras</em> e o app verificará sua compra pelo Apple ID — sem custo adicional.",
    },
];
---

<AppTemplate
    appId={appId}
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    socialImage={socialImage}
    socialImageAlt={socialImageAlt}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="pt-br"
    applicationCategory="GameApplication"
/>

---
import AppTemplate from "../../../../components/app/AppTemplate.astro";

const appId = 'id6749704116'
const title = 'LoopSize - Conversor de Tamanho de Anel'
const pageTitle = 'LoopSize | Conversor de Tamanho de Anéis para iPhone'
const description = 'LoopSize é um conversor de tamanho de anéis para iPhone com padrões BR, US, UK, EU/ISO, JP, CN e IN, medidas salvas e exportação em PDF.'
const favicon = "favicon-loopsize-32x32.png"
const appIcon = "loopsize/app-icon.png"

const metas = [
    { name: "apple-itunes-app", content: `app-id=6749704116` }
]
const primaryKeyword = "conversor de tamanho de anéis"
const secondaryKeywords = ["app de tamanho de anel para iPhone", "medição de anel", "exportar tamanho de anel em PDF"]

const screenshots = [
    {
        url: 'loopsize/screenshots/frame-1.png',
        alt: 'Tela inicial do LoopSize para encontrar o tamanho de anel ideal.',
        caption: 'Comece por um fluxo simples de medição no iPhone.',
    },
    {
        url: 'loopsize/screenshots/frame-2.png',
        alt: 'Tela de dimensão do anel no LoopSize.',
        caption: 'Meça dimensões do anel e compare padrões internacionais.',
    },
    {
        url: 'loopsize/screenshots/frame-3.png',
        alt: 'Tela de dimensão do dedo no LoopSize.',
        caption: 'Use a medida do dedo quando não tiver um anel por perto.',
    },
    {
        url: 'loopsize/screenshots/frame-4.png',
        alt: 'Tela de medidas salvas no LoopSize.',
        caption: 'Salve medidas para consultar novamente depois.',
    },
    {
        url: 'loopsize/screenshots/frame-5.png',
        alt: 'Alternância de unidade entre milímetros e polegadas no LoopSize.',
        caption: 'Alterne entre milímetros e polegadas conforme sua referência.',
    },
    {
        url: 'loopsize/screenshots/frame-6.png',
        alt: 'Tela de exportação em PDF do LoopSize para medidas de anel.',
        caption: 'Exporte uma folha de medição quando precisar de uma referência impressa.',
    }
]

const facts = [
    { label: "Plataforma", value: "iPhone" },
    { label: "Padrões", value: "BR, US, UK, EU/ISO, JP, CN, IN" },
    { label: "Exportação", value: "PDF imprimível" },
]

const features = [
    {
        title: "Conversão internacional",
        description: "Converta tamanhos de anéis entre BR, US, UK, EU/ISO, JP, CN e IN em um só lugar.",
    },
    {
        title: "Medidas salvas",
        description: "Mantenha medidas importantes organizadas para comparar ou compartilhar depois.",
    },
    {
        title: "Exportação em PDF",
        description: "Gere uma referência imprimível com orientação de escala real para saída em A4.",
    },
]

const useCases = [
    {
        title: "Comprar anéis online",
        description: "Compare sistemas de tamanho regionais antes de comprar em uma loja internacional.",
    },
    {
        title: "Presentes e medidas compartilhadas",
        description: "Salve e exporte medidas quando precisar de uma referência limpa para joalheria ou presente.",
    },
]

const faq = [
    {
        question: "Quais padrões de tamanho de anel o LoopSize suporta?",
        answer: "Suportamos BR, US, UK, EU/ISO, JP, CN e IN. Você pode alternar entre eles a qualquer momento.",
    },
    {
        question: "Posso salvar minhas medidas?",
        answer: "Sim! Com o plano <strong>Pro</strong>, você pode salvar medidas e exportá-las como PDF personalizado.",
    },
    {
        question: "Os tamanhos impressos correspondem ao tamanho real?",
        answer: "Sim. O PDF utiliza uma conversão mm→pt em escala real para A4. Recomendamos <em>verificar</em> com um cartão de crédito para confirmar a escala na primeira impressão.",
    },
    {
        question: "Funciona offline?",
        answer: "Sim, todos os cálculos são feitos localmente. As funcionalidades de compartilhamento podem requerer conexão com a internet.",
    },
    {
        question: "Como restaurar minhas compras?",
        answer: "Se você já adquiriu o LoopSize Pro, não precisa pagar novamente ao trocar de iPhone ou reinstalar o app. Basta tocar no botão \"Restaurar Compras\" na tela de pagamento e o app verificará automaticamente, pelo seu Apple ID, todas as suas compras anteriores.",
    }
];
---

<AppTemplate
    appId={appId}
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="pt-br"
    applicationCategory="UtilitiesApplication"
 />

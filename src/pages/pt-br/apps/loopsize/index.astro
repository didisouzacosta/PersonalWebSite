---
import AppTemplate from "../../../../components/app/AppTemplate.astro";

const appId = 'id6749704116'
const title = 'LoopSize - Tamanho de Anéis'
const pageTitle = 'LoopSize | Tamanho de Anéis para iPhone'
const appStoreUrl = "https://apps.apple.com/br/app/loopsize-tabela-de-an%C3%A9is/id6749704116";
const description = 'Meça, converta, salve e compartilhe tamanhos de anéis com diâmetro e circunferência precisos, padrões internacionais, iCloud, histórico e PDF com marca.'
const favicon = "apps/loopsize/favicon.png"
const appIcon = "loopsize/app-icon.png"
const socialImage = "loopsize/loopsize-share-pt-br.jpg"
const socialImageAlt = "Ícone do app LoopSize com resumo de tamanho e ferramenta de medição de anéis."

const metas = [
    { name: "apple-itunes-app", content: `app-id=6749704116` }
]
const primaryKeyword = "tamanho de anel"
const secondaryKeywords = [

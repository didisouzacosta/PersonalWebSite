    {
        url: {
            en: 'loopsize/screenshots/en/frame-4.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-4.png',
        },
        alt: 'Tela de compartilhamento em PDF do LoopSize com personalização de marca para medidas de anel.',
        caption: 'Compartilhe um PDF claro e personalize o arquivo com sua marca.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-5.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-5.png',
        },
        alt: 'Tela de medições salvas no LoopSize com tamanhos de anel e preferências sincronizados pelo iCloud.',
        caption: 'Salve medições, preferências e tamanhos de anel com sincronização pelo iCloud.',

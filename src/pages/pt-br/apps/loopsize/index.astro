    },
    {
        title: "Conversão internacional",
        description: "Converta instantaneamente entre BR, US, UK, EU/ISO, JP, CN e IN ao comprar online, viajar ou atender um cliente.",
    },
    {
        title: "Dimensões precisas",
        description: "Mantenha diâmetro e circunferência visíveis para decidir com base em medidas exatas, não apenas em uma tabela.",
    },
    {
        title: "Compartilhamento em PDF",
        description: "Compartilhe um PDF claro com joalheria, cliente, parceiro, familiar ou para consultar depois.",
    },
    {
        title: "PDF com marca",
        description: "Usuários Pro podem personalizar PDFs exportados com sua marca para uma entrega mais profissional.",

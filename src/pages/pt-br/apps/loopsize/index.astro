    },
    {
        title: "Atendimento em joalherias",
        description: "Meça anéis ou dedos, explique conversões e envie PDFs profissionais após uma conversa de medição.",
    },
]

const faq = [
    {
        question: "Quais padrões de tamanho de anel o LoopSize suporta?",
        answer: "LoopSize converte instantaneamente entre os padrões BR, US, UK, EU/ISO, JP, CN e IN.",
    },
    {
        question: "Posso salvar minhas medidas?",
        answer: "Sim. Com o <strong>LoopSize Pro</strong>, você pode manter histórico de medições, salvar tamanhos de anel e sincronizar medições e preferências com o iCloud.",

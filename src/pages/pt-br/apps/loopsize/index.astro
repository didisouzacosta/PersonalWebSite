        },
        alt: 'Tela inicial do LoopSize para encontrar e compartilhar o tamanho de anel ideal.',
        caption: 'Comece por um fluxo simples para encontrar seu tamanho de anel ideal.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-2.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-2.png',
        },
        alt: 'Tela de conversão do LoopSize com padrões BR, US, UK, EU/ISO, JP, CN e IN.',
        caption: 'Converta instantaneamente entre os padrões BR, US, UK, EU/ISO, JP, CN e IN.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-3.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-3.png',
        },
        alt: 'Tela de dimensões do LoopSize com valores precisos de diâmetro e circunferência.',

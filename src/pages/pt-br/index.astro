---
import AboutMe from '../../components/resume/AboutMe.astro';
import Layout from '../../layouts/Layout.astro';
import { homepagePtBr } from '../../core/homepage';
import { localizedAlternates, personJsonLd, websiteJsonLd } from '../../core/seo';
---

<Layout
	title={homepagePtBr.title}
	description={homepagePtBr.description}
	lang="pt-br"
	metas={[]}
	canonicalPath="/pt-br/"
	alternateLocales={localizedAlternates("/", "/pt-br/")}
	jsonLd={[personJsonLd("pt-br"), websiteJsonLd("pt-br")]}
>
	<AboutMe content={homepagePtBr} />
</Layout>

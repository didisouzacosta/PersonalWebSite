---
import AboutMe from '../components/resume/AboutMe.astro';
import Layout from '../layouts/Layout.astro';
import { homepageEn } from '../core/homepage';
import { localizedAlternates, personJsonLd, websiteJsonLd } from '../core/seo';
---

<Layout
	title={homepageEn.title}
	description={homepageEn.description}
	lang="en"
	metas={[]}
	canonicalPath="/"
	alternateLocales={localizedAlternates("/", "/pt-br/")}
	jsonLd={[personJsonLd("en"), websiteJsonLd("en")]}
>
	<AboutMe content={homepageEn} />
</Layout>

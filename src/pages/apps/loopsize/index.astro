---
import AppTemplate from "../../../components/app/AppTemplate.astro";

const appId = 'id6749704116'
const title = 'LoopSize - Ring Size Converter'
const pageTitle = 'LoopSize | Ring Size Converter for iPhone'
const description = 'LoopSize makes it easy to find and share your perfect ring size with instant conversions, precise dimensions, saved sizes, iCloud sync, and PDF sharing.'
const favicon = "apps/loopsize/favicon.png"
const appIcon = "loopsize/app-icon.png"
const socialImage = "loopsize/loopsize-share-en.jpg"
const socialImageAlt = "LoopSize app icon with ring size converter app summary."

const metas = [
    { name: "apple-itunes-app", content: `app-id=6749704116` }
]
const primaryKeyword = "ring size"
const secondaryKeywords = [
    "ring sizer",
    "ring measurement",
    "ring converter",
    "jewelry tool",
    "ring chart",
    "ring size finder",
]

const screenshots = [
    {
        url: {
            en: 'loopsize/screenshots/en/frame-1.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-1.png',
        },
        alt: 'LoopSize home screen for finding and sharing the perfect ring size.',
        caption: 'Start from a simple workflow to find your perfect ring size.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-2.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-2.png',
        },
        alt: 'LoopSize conversion screen showing BR, US, UK, EU/ISO, JP, CN, and IN ring standards.',
        caption: 'Convert instantly between BR, US, UK, EU/ISO, JP, CN, and IN standards.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-3.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-3.png',
        },
        alt: 'LoopSize dimensions screen with precise diameter and circumference values.',
        caption: 'Check diameter and circumference with high precision.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-4.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-4.png',
        },
        alt: 'LoopSize saved ring sizes screen with iCloud-synced measurements.',
        caption: 'Save your ring sizes and keep them synced with iCloud.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-5.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-5.png',
        },
        alt: 'LoopSize dimension standards screen for comparing ring size details.',
        caption: 'See all dimension standards when you need a complete comparison.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-6.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-6.png',
        },
        alt: 'LoopSize PDF sharing screen with brand personalization for ring measurements.',
        caption: 'Share measurements in PDF and personalize the file with your brand.',
    }
]

const facts = [
    { label: "Platform", value: "iPhone" },
    { label: "Standards", value: "BR, US, UK, EU/ISO, JP, CN, IN" },
    { label: "Dimensions", value: "Diameter + circumference" },
    { label: "Sharing", value: "Personalized PDF" },
]

const features = [
    {
        title: "Instant size conversion",
        description: "Convert instantly between BR, US, UK, EU/ISO, JP, CN, and IN ring size standards.",
    },
    {
        title: "Precise dimensions",
        description: "Check diameter and circumference with high precision when comparing measurements.",
    },
    {
        title: "PDF sharing",
        description: "Share your measurements in a clean PDF whenever you need a reference for yourself, a jeweler, or a gift.",
    },
    {
        title: "Pro branded PDFs",
        description: "Personalize the exported PDF with your own brand for a more professional handoff.",
    },
    {
        title: "Pro saved sizes",
        description: "Save your ring sizes and keep them synced with iCloud across your devices.",
    },
    {
        title: "Pro dimension standards",
        description: "See all dimension standards in one place for faster international comparisons.",
    },
]

const useCases = [
    {
        title: "Finding your size",
        description: "Identify the right ring size from your preferred standard and compare it against international charts.",
    },
    {
        title: "Sharing measurements",
        description: "Send a PDF with your measurements when buying jewelry, planning a gift, or working with a jeweler.",
    },
]

const faq = [
    {
        question: "Which ring size standards does LoopSize support?",
        answer: "LoopSize converts instantly between BR, US, UK, EU/ISO, JP, CN, and IN ring size standards.",
    },
    {
        question: "Can I save my measurements?",
        answer: "Yes. With <strong>LoopSize Pro</strong>, you can save your ring sizes and sync them with iCloud.",
    },
    {
        question: "Can I share my ring size?",
        answer: "Yes. LoopSize lets you share your measurements in PDF, and Pro users can personalize the PDF with their brand.",
    },
    {
        question: "Does LoopSize show ring dimensions?",
        answer: "Yes. You can check diameter and circumference with high precision, plus all dimension standards with LoopSize Pro.",
    },
    {
        question: "Does it work offline?",
        answer: "Yes, all calculations are done locally. Sharing features may require an internet connection.",
    },
    {
        question: "How do I restore my purchases?",
        answer: "If you’ve already purchased LoopSize Pro, you don’t need to pay again when switching to a new iPhone or reinstalling the app. Simply tap the “Restore Purchases” button in the paywall and the app will automatically check, through your Apple ID, all your previous purchases and subscriptions. If there’s an active subscription or lifetime purchase, Pro access will be unlocked instantly — at no extra cost.",
    }
];
---

<AppTemplate
    appId={appId}
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    socialImage={socialImage}
    socialImageAlt={socialImageAlt}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="en"
    applicationCategory="UtilitiesApplication"
 />

---
import AppTemplate from "../../../components/app/AppTemplate.astro";

const appId = 'id6749704116'
const title = 'LoopSize - Ring Sizer Chart'
const pageTitle = 'LoopSize | Ring Sizer Chart for iPhone'
const appStoreUrl = "https://apps.apple.com/us/app/loopsize-ring-size-converter/id6749704116";
const description = 'Measure, convert, save, and share ring sizes with precise diameter and circumference tools, international standards, iCloud sync, history, and branded PDF export.'
const favicon = "apps/loopsize/favicon.png"
const appIcon = "loopsize/app-icon.png"
const socialImage = "loopsize/loopsize-share-en.jpg"
const socialImageAlt = "LoopSize app icon with ring measurement and ring sizer chart summary."

const metas = [
    { name: "apple-itunes-app", content: `app-id=6749704116` }
]
const primaryKeyword = "ring size"
const secondaryKeywords = [
    "ring sizer",
    "ring measurement",
    "ring converter",
    "ring size chart",
    "jewelry tool",
    "ring size finder",
    "ring size PDF",
]

const screenshots = [
    {
        url: {
            en: 'loopsize/screenshots/en/frame-1.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-1.png',
        },
        alt: 'LoopSize home screen for finding and sharing the perfect ring size.',
        caption: 'Start from a simple workflow to find your perfect ring size.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-2.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-2.png',
        },
        alt: 'LoopSize conversion screen showing BR, US, UK, EU/ISO, JP, CN, and IN ring standards.',
        caption: 'Convert instantly between BR, US, UK, EU/ISO, JP, CN, and IN standards.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-3.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-3.png',
        },
        alt: 'LoopSize dimensions screen with precise diameter and circumference values.',
        caption: 'Check diameter and circumference with high precision.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-4.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-4.png',
        },
        alt: 'LoopSize saved measurements screen with iCloud-synced ring sizes and preferences.',
        caption: 'Save measurements, preferences, and ring sizes with iCloud sync.',
    },
    {
        url: {
            en: 'loopsize/screenshots/en/frame-5.png',
            ptBr: 'loopsize/screenshots/ptBR/frame-5.png',
        },
        alt: 'LoopSize PDF sharing screen with brand personalization for ring measurements.',
        caption: 'Share a clear PDF and personalize it with your brand.',
    }
]

const facts = [
    { label: "Platform", value: "iPhone" },
    { label: "Version", value: "1.2.0" },
    { label: "Standards", value: "BR, US, UK, EU/ISO, JP, CN, IN" },
    { label: "Dimensions", value: "Diameter + circumference" },
    { label: "Pro", value: "iCloud + branded PDF" },
]

const features = [
    {
        title: "Ring and finger measurement",
        description: "Start from diameter or circumference, then compare the real measurement behind each ring size.",
    },
    {
        title: "International conversion",
        description: "Convert instantly between BR, US, UK, EU/ISO, JP, CN, and IN standards when shopping online, traveling, or helping a customer.",
    },
    {
        title: "Precise dimensions",
        description: "Keep diameter and circumference visible so ring decisions are based on exact measurements, not only a chart.",
    },
    {
        title: "PDF sharing",
        description: "Share a clear measurement PDF with a jeweler, customer, partner, family member, or your future self.",
    },
    {
        title: "Branded PDF export",
        description: "Pro users can personalize exported PDFs with their brand for a more professional customer handoff.",
    },
    {
        title: "iCloud sync and history",
        description: "Pro users can sync measurements and preferences with iCloud, then revisit saved history for repeat customers, future purchases, or adjustments.",
    },
]

const useCases = [
    {
        title: "Buying online or choosing a gift",
        description: "Check a ring size before purchasing, compare international charts, and save possible measurements with more confidence.",
    },
    {
        title: "Jewelry consultations",
        description: "Measure rings or fingers, explain conversions, and send polished PDFs to customers after a sizing conversation.",
    },
]

const faq = [
    {
        question: "Which ring size standards does LoopSize support?",
        answer: "LoopSize converts instantly between BR, US, UK, EU/ISO, JP, CN, and IN ring size standards.",
    },
    {
        question: "Can I save my measurements?",
        answer: "Yes. With <strong>LoopSize Pro</strong>, you can keep a history of measurements, save ring sizes, and sync measurements and preferences with iCloud.",
    },
    {
        question: "Can I share my ring size?",
        answer: "Yes. LoopSize lets you share your measurements in PDF, and Pro users can personalize the PDF with their brand.",
    },
    {
        question: "Does LoopSize show ring dimensions?",
        answer: "Yes. You can measure by diameter or circumference, keep both values visible, and compare the equivalent size across supported standards.",
    },
    {
        question: "What changed in the latest version?",
        answer: "Version 1.2.0 adds branded PDF customization, iCloud sync for measurements and preferences, accessibility improvements, and an enhanced ring and finger size marker.",
    },
    {
        question: "Does it work offline?",
        answer: "Yes, all calculations are done locally. Sharing features may require an internet connection.",
    },
    {
        question: "How do I restore my purchases?",
        answer: "If you’ve already purchased LoopSize Pro, you don’t need to pay again when switching to a new iPhone or reinstalling the app. Simply tap the “Restore Purchases” button in the paywall and the app will automatically check, through your Apple ID, all your previous purchases and subscriptions. If there’s an active subscription or lifetime purchase, Pro access will be unlocked instantly — at no extra cost.",
    }
];
---

<AppTemplate
    appId={appId}
    appStoreUrl={appStoreUrl}
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    socialImage={socialImage}
    socialImageAlt={socialImageAlt}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="en"
    applicationCategory="UtilitiesApplication"
 />

---
import AppTemplate from "../../../components/app/AppTemplate.astro";

const appId = 'id6749704116'
const title = 'LoopSize - Ring Size Converter'
const pageTitle = 'LoopSize | Ring Size Converter for iPhone'
const description = 'LoopSize is an iPhone ring size converter for BR, US, UK, EU/ISO, JP, CN, and IN sizes, with saved measurements and PDF export.'
const favicon = "favicon-loopsize-32x32.png"
const appIcon = "loopsize/app-icon.png"
const socialImage = "/social/apps/loopsize-share-en.jpg"
const socialImageAlt = "LoopSize app icon with ring size converter app summary."

const metas = [
    { name: "apple-itunes-app", content: `app-id=6749704116` }
]
const primaryKeyword = "ring size converter"
const secondaryKeywords = ["iPhone ring size app", "ring measurement", "ring size PDF export"]

const screenshots = [
    {
        url: 'loopsize/screenshots/frame-1.png',
        alt: 'LoopSize home screen for finding the perfect ring size.',
        caption: 'Start from a simple ring size workflow on iPhone.',
    },
    {
        url: 'loopsize/screenshots/frame-2.png',
        alt: 'LoopSize ring dimension screen for measuring a ring.',
        caption: 'Measure ring dimensions and compare international sizes.',
    },
    {
        url: 'loopsize/screenshots/frame-3.png',
        alt: 'LoopSize finger dimension screen for measuring finger size.',
        caption: 'Use finger dimensions when you do not have a ring nearby.',
    },
    {
        url: 'loopsize/screenshots/frame-4.png',
        alt: 'LoopSize saved measurements screen.',
        caption: 'Save measurements so you can return to them later.',
    },
    {
        url: 'loopsize/screenshots/frame-5.png',
        alt: 'LoopSize unit switch between millimeters and inches.',
        caption: 'Switch between millimeters and inches for familiar measurements.',
    },
    {
        url: 'loopsize/screenshots/frame-6.png',
        alt: 'LoopSize PDF export screen for saved ring measurements.',
        caption: 'Export a measurement sheet when you need a printable reference.',
    }
]

const facts = [
    { label: "Platform", value: "iPhone" },
    { label: "Standards", value: "BR, US, UK, EU/ISO, JP, CN, IN" },
    { label: "Export", value: "Printable PDF" },
]

const features = [
    {
        title: "International size conversion",
        description: "Convert ring sizes across BR, US, UK, EU/ISO, JP, CN, and IN standards from one place.",
    },
    {
        title: "Saved measurements",
        description: "Keep important measurements organized so you can compare or share them later.",
    },
    {
        title: "PDF export",
        description: "Generate a printable measurement reference with true-to-scale guidance for A4 output.",
    },
]

const useCases = [
    {
        title: "Buying rings online",
        description: "Compare regional sizing systems before ordering from an international store.",
    },
    {
        title: "Gifts and shared measurements",
        description: "Save and export measurements when you need a clean reference for a jeweler or gift.",
    },
]

const faq = [
    {
        question: "Which ring size standards does LoopSize support?",
        answer: "We support BR, US, UK, EU/ISO, JP, CN, and IN. You can switch between them at any time.",
    },
    {
        question: "Can I save my measurements?",
        answer: "Yes! With the <strong>Pro</strong> plan, you can save measurements and export them as a custom PDF.",
    },
    {
        question: "Do the printed sizes match the real size?",
        answer: "Yes. The PDF uses a true-to-scale mm→pt conversion for A4. We recommend <em>checking</em> with a credit card to confirm the scale on your first print.",
    },
    {
        question: "Does it work offline?",
        answer: "Yes, all calculations are done locally. Sharing features may require an internet connection.",
    },
    {
        question: "How do I restore my purchases?",
        answer: "If you’ve already purchased LoopSize Pro, you don’t need to pay again when switching to a new iPhone or reinstalling the app. Simply tap the “Restore Purchases” button in the paywall and the app will automatically check, through your Apple ID, all your previous purchases and subscriptions. If there’s an active subscription or lifetime purchase, Pro access will be unlocked instantly — at no extra cost.",
    }
];
---

<AppTemplate
    appId={appId}
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    socialImage={socialImage}
    socialImageAlt={socialImageAlt}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="en"
    applicationCategory="UtilitiesApplication"
 />

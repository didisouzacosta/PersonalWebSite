---
import AppTemplate from "../../../components/app/AppTemplate.astro";

const appId = "id6757385646";
const title = "KuboRush - Block Puzzle";
const pageTitle = "KuboRush | Block Puzzle Game for iOS";
const description =
    "KuboRush is a casual block puzzle game where you fit pieces, think fast, and clear the board at your own pace. Perfect for your spare 2 minutes — no pressure, just fun.";
const favicon = "favicon-kuborush-32x32.png";
const appIcon = "kuborush/app-icon.png";

const metas = [{ name: "apple-itunes-app", content: `app-id=6757385646` }];
const primaryKeyword = "block puzzle game";
const secondaryKeywords = ["iOS puzzle game", "casual puzzle game", "weekly puzzle challenges"];

const screenshots = [
    {
        url: "kuborush/screenshots/frame-1.png",
        alt: "KuboRush block puzzle start screen for a quick casual game session.",
        caption: "Start a short block puzzle session whenever you have a few minutes.",
    },
    {
        url: "kuborush/screenshots/frame-2.png",
        alt: "KuboRush board showing piece placement controls.",
        caption: "Plan each move and keep control of the board.",
    },
    {
        url: "kuborush/screenshots/frame-3.png",
        alt: "KuboRush combo screen with matched block puzzle pieces.",
        caption: "Match pieces, clear space, and build stronger combos.",
    },
    {
        url: "kuborush/screenshots/frame-4.png",
        alt: "KuboRush competitive modes with Hall of Fame and Weekly Rush.",
        caption: "Compete through Hall of Fame rankings and Weekly Rush challenges.",
    },
];

const facts = [
    { label: "Platform", value: "iOS" },
    { label: "Session length", value: "Quick play" },
    { label: "Modes", value: "Hall of Fame + Weekly Rush" },
];

const features = [
    {
        title: "No-pressure puzzle play",
        description: "Fit blocks and clear the board at your own pace, without a timer pushing every move.",
    },
    {
        title: "Helpful power-ups",
        description: "Use Hint, Shuffle, Rotate, and Undo when you want a nudge or a second chance.",
    },
    {
        title: "Competitive challenges",
        description: "Climb Hall of Fame leaderboards and return for Weekly Rush events with fresh goals.",
    },
];

const useCases = [
    {
        title: "Short breaks",
        description: "Play a satisfying puzzle round during spare minutes without committing to a long session.",
    },
    {
        title: "Strategy practice",
        description: "Experiment with placement, rotation, and undo to learn better board-clearing patterns.",
    },
];

const faq = [
    {
        question: "What is KuboRush?",
        answer: "KuboRush is a casual block puzzle game where you fit pieces, think fast, and clear the board at your own pace — no time limits, no pressure. It’s designed to be the most fun 2 minutes of your day.",
    },
    {
        question: "What power-ups are available?",
        answer: "KuboRush has four power-ups to keep you going: <strong>Hint</strong> gives you a nudge when you’re stuck, <strong>Shuffle</strong> brings a fresh set of pieces, <strong>Rotate</strong> lets you spin a piece to find the perfect fit, and <strong>Undo</strong> lets you take back up to 3 moves so you can experiment freely.",
    },
    {
        question: "What are the competitive modes?",
        answer: "There are two competitive modes: <strong>Hall of Fame</strong>, where you compete with friends through global leaderboards, and <strong>Weekly Rush</strong>, a weekly event with special challenges to test your skills and strategy.",
    },
    {
        question: "Is KuboRush free?",
        answer: "Yes, KuboRush is free to download and play. A <strong>KuboRush Pro</strong> upgrade is available as a one-time in-app purchase, unlocking additional features to enhance your experience.",
    },
    {
        question: "How do I restore my purchase?",
        answer: "If you’ve already purchased KuboRush Pro, you don’t need to pay again when switching devices or reinstalling the app. Simply tap the <em>Restore Purchases</em> button and the app will verify your purchase through your Apple ID — at no extra cost.",
    },
];
---

<AppTemplate
    appId={appId}
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="en"
    applicationCategory="GameApplication"
/>

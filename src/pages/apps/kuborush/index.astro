---
import AppTemplate from "../../../components/app/AppTemplate.astro";

const appId = "id6757385646";
const title = "KuboRush - Block Puzzle";
const pageTitle = "KuboRush | Block Puzzle Game for iOS";
const description =
    "KuboRush is a smart and relaxing block puzzle game for quick 2-minute breaks. Place your pieces, think strategically, and clear the board at your own pace.";
const favicon = "apps/kuborush/favicon.png";
const appIcon = "kuborush/app-icon.png";
const socialImage = "/social/apps/kuborush-share-en.jpg";
const socialImageAlt = "KuboRush app icon with block puzzle app summary.";

const metas = [{ name: "apple-itunes-app", content: `app-id=6757385646` }];
const primaryKeyword = "puzzle";
const secondaryKeywords = [
    "relax",
    "quick",
    "blocks",
    "cube",
    "challenge",
    "logic",
    "board",
    "competitive",
    "pastime",
    "brain",
    "casual",
];

const screenshots = [
    {
        url: {
            en: "kuborush/screenshots/en/frame-1.png",
            ptBr: "kuborush/screenshots/ptBR/frame-1.png",
        },
        alt: "KuboRush start screen introducing quick, relaxing block puzzle breaks.",
        caption: "Open KuboRush whenever you want a smart 2-minute puzzle break.",
    },
    {
        url: {
            en: "kuborush/screenshots/en/frame-2.png",
            ptBr: "kuborush/screenshots/ptBR/frame-2.png",
        },
        alt: "KuboRush board with pieces ready to place, rotate, shuffle, or solve with a hint.",
        caption: "Place pieces strategically and use Hint, Shuffle, or Rotate when you need control.",
    },
    {
        url: {
            en: "kuborush/screenshots/en/frame-3.png",
            ptBr: "kuborush/screenshots/ptBR/frame-3.png",
        },
        alt: "KuboRush gameplay showing cleared blocks, board strategy, and undo-friendly moves.",
        caption: "Clear the board at your pace and undo up to your last 3 moves if you change your mind.",
    },
    {
        url: {
            en: "kuborush/screenshots/en/frame-4.png",
            ptBr: "kuborush/screenshots/ptBR/frame-4.png",
        },
        alt: "KuboRush competitive screens for Hall of Fame rankings and Weekly Rush events.",
        caption: "Show your skills in the Hall of Fame or join the Weekly Rush event.",
    },
];

const facts = [
    { label: "Platform", value: "iOS" },
    { label: "Break length", value: "2-minute sessions" },
    { label: "Play style", value: "Relaxed strategy" },
    { label: "Competition", value: "Hall of Fame + Weekly Rush" },
];

const features = [
    {
        title: "Full Move Control",
        description: "Stuck? Use Hint for the best move, Shuffle for new pieces, or Rotate for the perfect fit.",
    },
    {
        title: "Play Fearlessly",
        description: "Made a mistake? Undo lets you reverse up to your last 3 moves so you can keep experimenting.",
    },
    {
        title: "Friendly Competition",
        description: "Show off your skills with friends in the Hall of Fame or join the exciting Weekly Rush event.",
    },
];

const useCases = [
    {
        title: "Quick breaks",
        description: "Turn short pauses into smart, relaxing puzzle moments that recharge your mind.",
    },
    {
        title: "Relaxed strategy",
        description: "Place pieces, plan ahead, and clear the board at your own pace with no stress.",
    },
];

const faq = [
    {
        question: "What is KuboRush?",
        answer: "KuboRush is a smart and relaxing block puzzle game made for quick 2-minute breaks. Place your pieces, think strategically, and clear the board at your own pace.",
    },
    {
        question: "What power-ups are available?",
        answer: "KuboRush gives you full move control: <strong>Hint</strong> shows the best move when you are stuck, <strong>Shuffle</strong> brings new pieces, <strong>Rotate</strong> helps you find the perfect fit, and <strong>Undo</strong> reverses up to your last 3 moves.",
    },
    {
        question: "What are the competitive modes?",
        answer: "There are two competitive modes: <strong>Hall of Fame</strong>, where you compete with friends through global leaderboards, and <strong>Weekly Rush</strong>, a weekly event with special challenges to test your skills and strategy.",
    },
    {
        question: "Is KuboRush free?",
        answer: "Yes, KuboRush is free to download and play. A <strong>KuboRush Pro</strong> upgrade is available as a one-time in-app purchase, unlocking additional features to enhance your experience.",
    },
    {
        question: "How do I restore my purchase?",
        answer: "If you’ve already purchased KuboRush Pro, you don’t need to pay again when switching devices or reinstalling the app. Simply tap the <em>Restore Purchases</em> button and the app will verify your purchase through your Apple ID — at no extra cost.",
    },
];
---

<AppTemplate
    appId={appId}
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    socialImage={socialImage}
    socialImageAlt={socialImageAlt}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="en"
    applicationCategory="GameApplication"
/>

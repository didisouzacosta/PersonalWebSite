    },
    {
        url: {
            en: "duotake/screenshots/en/frame-2.png",
            ptBr: "duotake/screenshots/ptBR/frame-2.png",
        },
        alt: "DuoTake dual-camera recording screen showing a mountain view with a selfie reaction overlay.",
        caption: "Show the moment and your expression together in a single recording.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-3.png",
            ptBr: "duotake/screenshots/ptBR/frame-3.png",
        },
        alt: "DuoTake Cover layout showing a full-screen picnic scene with a group selfie camera overlaid.",
        caption: "Use Cover to highlight one camera full-screen while keeping the other view overlaid.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-4.png",
            ptBr: "duotake/screenshots/ptBR/frame-4.png",
        },
        alt: "DuoTake Teleprompter recording screen with a script overlay in front of the camera view.",
        caption: "Follow your script on screen with the premium Teleprompter while recording.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-5.png",
            ptBr: "duotake/screenshots/ptBR/frame-5.png",
        },

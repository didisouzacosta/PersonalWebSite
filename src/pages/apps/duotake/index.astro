---
import AppTemplate from "../../../components/app/AppTemplate.astro";

const title = "DuoTake";
const pageTitle = "DuoTake | Dual Camera App for Reaction Videos";
const description =
    "DuoTake lets you record or take photos with the front and back cameras at the same time, plus CropOut to create cleaner framing that is perfect for reacts.";
const favicon = "favicon-duotake-32x32.png";
const appIcon = "duotake/app-icon.png";

const metas = [];

const screenshots = [
    {
        url: "duotake/screenshots/frame-1.png",
        alt: "Capture portrait and landscape at the same time.",
    },
    {
        url: "duotake/screenshots/frame-2.png",
        alt: "Choose the best mode for dual-format recording.",
    },
    {
        url: "duotake/screenshots/frame-3.png",
        alt: "Adjust camera settings before every take.",
    },
    {
        url: "duotake/screenshots/frame-4.png",
        alt: "Shoot photos and videos ready for every platform.",
    },
];

const faq = [
    {
        question: "What is DuoTake?",
        answer: "DuoTake is a camera app built to capture with the front and back cameras at the same time, for both photos and videos. It also includes <strong>CropOut</strong>, which helps create a framing style that works especially well for reacts and reaction-style content.",
    },
    {
        question: "Who is DuoTake for?",
        answer: "DuoTake is ideal for creators, social media managers, vloggers, and anyone producing reacts, commentary, or behind-the-scenes content who wants to show both the scene and their reaction at once.",
    },
    {
        question: "Can I take both photos and videos?",
        answer: "Yes. DuoTake supports photos and videos using the front and rear cameras simultaneously, making it easier to capture your reaction and what you are looking at in a single shot.",
    },
    {
        question: "Does DuoTake work offline?",
        answer: "Yes. Core capture and media processing are designed to work directly on your device. Features that depend on Apple services, such as purchase validation or saving to your photo library, may require the corresponding system permissions.",
    },
    {
        question: "How do I restore my purchase?",
        answer: "If you already unlocked DuoTake premium features, tap <em>Restore Purchases</em> and the app will ask Apple to verify your previous purchase using the same Apple ID — with no extra charge.",
    },
];
---

<AppTemplate
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    description={description}
    screenshots={screenshots}
    faq={faq}
    lang="en"
    applicationCategory="MultimediaApplication"
/>

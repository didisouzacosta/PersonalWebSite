---
import AppTemplate from "../../../components/app/AppTemplate.astro";

const title = "DuoTake";
const pageTitle = "DuoTake | Dual Camera App for Reaction Videos";
const description =
    "DuoTake is an iPhone dual camera app for recording reaction videos with the front and back cameras at the same time, plus CropOut for cleaner framing.";
const favicon = "favicon-duotake-32x32.png";
const appIcon = "duotake/app-icon.png";

const metas = [];
const primaryKeyword = "dual camera app";
const secondaryKeywords = ["reaction video app", "front and back camera", "iPhone camera app"];

const screenshots = [
    {
        url: "duotake/screenshots/frame-1.png",
        alt: "DuoTake dual camera capture showing portrait and landscape at the same time.",
        caption: "Capture the scene and your reaction in one take.",
    },
    {
        url: "duotake/screenshots/frame-2.png",
        alt: "DuoTake mode selection for dual-format recording.",
        caption: "Choose the recording mode that fits the platform you are creating for.",
    },
    {
        url: "duotake/screenshots/frame-3.png",
        alt: "DuoTake camera settings screen before a dual-camera take.",
        caption: "Adjust camera settings before every photo or video.",
    },
    {
        url: "duotake/screenshots/frame-4.png",
        alt: "DuoTake photo and video capture options for social platforms.",
        caption: "Shoot photos and videos ready for reaction-style posts.",
    },
];

const facts = [
    { label: "Platform", value: "iPhone" },
    { label: "Best for", value: "Reaction videos" },
    { label: "Capture", value: "Front + back cameras" },
];

const features = [
    {
        title: "Dual-camera capture",
        description: "Record the scene and your reaction at the same time using the front and rear cameras.",
    },
    {
        title: "CropOut framing",
        description: "Create cleaner framing for reaction-style videos without rebuilding your setup after each take.",
    },
    {
        title: "Photo and video modes",
        description: "Capture stills or videos depending on the format you need for your post.",
    },
];

const useCases = [
    {
        title: "Reaction creators",
        description: "Show what you are watching and your response in one ready-to-share capture.",
    },
    {
        title: "Behind-the-scenes posts",
        description: "Record the moment and the person behind the camera without switching apps.",
    },
];

const faq = [
    {
        question: "What is DuoTake?",
        answer: "DuoTake is a camera app built to capture with the front and back cameras at the same time, for both photos and videos. It also includes <strong>CropOut</strong>, which helps create a framing style that works especially well for reacts and reaction-style content.",
    },
    {
        question: "Who is DuoTake for?",
        answer: "DuoTake is ideal for creators, social media managers, vloggers, and anyone producing reacts, commentary, or behind-the-scenes content who wants to show both the scene and their reaction at once.",
    },
    {
        question: "Can I take both photos and videos?",
        answer: "Yes. DuoTake supports photos and videos using the front and rear cameras simultaneously, making it easier to capture your reaction and what you are looking at in a single shot.",
    },
    {
        question: "Does DuoTake work offline?",
        answer: "Yes. Core capture and media processing are designed to work directly on your device. Features that depend on Apple services, such as purchase validation or saving to your photo library, may require the corresponding system permissions.",
    },
    {
        question: "How do I restore my purchase?",
        answer: "If you already unlocked DuoTake premium features, tap <em>Restore Purchases</em> and the app will ask Apple to verify your previous purchase using the same Apple ID — with no extra charge.",
    },
];
---

<AppTemplate
    title={title}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="en"
    applicationCategory="MultimediaApplication"
/>

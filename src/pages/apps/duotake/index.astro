---
import AppTemplate from "../../../components/app/AppTemplate.astro";

const title = "DuoTake: Reaction Dual Cam";
const appId = "id6761627384";
const appStoreUrl = "https://apps.apple.com/us/app/duotake-reaction-dual-cam/id6761627384";
const appName = "DuoTake";
const pageTitle = "DuoTake: Reaction Dual Cam";
const description =
    "Record what happens and how you react in one video with front and rear cameras, creator layouts, CropOut, and a premium Teleprompter.";
const favicon = "apps/duotake/favicon.png";
const appIcon = "duotake/app-icon.png";
const socialImage = "duotake/duotake-share-en.jpg";
const socialImageAlt = "DuoTake app icon with reaction dual cam app summary.";

const metas = [{ name: "apple-itunes-app", content: "app-id=6761627384" }];
const primaryKeyword = "reaction dual cam app";
const secondaryKeywords = [
    "reaction video app",
    "video editor",
    "front and back camera",
    "teleprompter app",
    "scripted video recording",
    "content creator app",
    "record video",
    "TikTok Reels Shorts",
];

const screenshots = [
    {
        url: {
            en: "duotake/screenshots/en/frame-1.png",
            ptBr: "duotake/screenshots/ptBR/frame-1.png",
        },

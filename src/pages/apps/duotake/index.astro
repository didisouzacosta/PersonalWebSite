---
import AppTemplate from "../../../components/app/AppTemplate.astro";

const title = "DuoTake: Dual Camera";
const appName = "DuoTake";
const pageTitle = "DuoTake: Dual Camera";
const description =
    "Record with the front and back cameras at the same time. Capture the moment and your reaction in one take, ready for TikTok, Reels, and Shorts.";
const favicon = "apps/duotake/favicon.png";
const appIcon = "duotake/app-icon.png";
const testFlightUrl = "https://testflight.apple.com/join/2pGeFVPg";
const socialImage = "duotake/duotake-share-en.jpg";
const socialImageAlt = "DuoTake app icon with dual camera app summary.";

const metas = [];
const primaryKeyword = "dual camera app";
const secondaryKeywords = [
    "reaction video app",
    "video editor",
    "front and back camera",
    "content creator app",
    "record video",
    "TikTok Reels Shorts",
];

const screenshots = [
    {
        url: {
            en: "duotake/screenshots/en/frame-1.png",
            ptBr: "duotake/screenshots/ptBR/frame-1.png",
        },
        alt: "DuoTake examples showing front and back camera recording layouts at the same time.",
        caption: "Capture front and back cameras together in the layout that fits the moment.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-2.png",
            ptBr: "duotake/screenshots/ptBR/frame-2.png",
        },
        alt: "DuoTake recording screen at a stadium with a reaction window over the back camera view.",
        caption: "Keep the scene and your reaction together in one recording.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-3.png",
            ptBr: "duotake/screenshots/ptBR/frame-3.png",
        },
        alt: "DuoTake automatic cutout preview keeping the person cleanly framed over the background.",
        caption: "Use automatic cutout to keep reactions clean and focused.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-4.png",
            ptBr: "duotake/screenshots/ptBR/frame-4.png",
        },
        alt: "DuoTake dual camera layouts showing aquarium and outdoor pet recording examples.",
        caption: "Show the moment and your expression from two angles at the same time.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-5.png",
            ptBr: "duotake/screenshots/ptBR/frame-5.png",
        },
        alt: "DuoTake editor presets screen with social, square, portrait, and landscape formats.",
        caption: "Choose ready-to-post formats for Reels, TikTok, Shorts, and more.",
    },
    {
        url: {
            en: "duotake/screenshots/en/frame-6.png",
            ptBr: "duotake/screenshots/ptBR/frame-6.png",
        },
        alt: "DuoTake export screen with output quality options for the finished video.",
        caption: "Export finished videos in high quality, up to the original resolution.",
    },
];

const facts = [
    { label: "Platform", value: "iPhone" },
    { label: "Best for", value: "Creators, reviews, reacts" },
    { label: "Output", value: "TikTok, Reels, Shorts" },
];

const features = [
    {
        title: "Dual-camera recording",
        description: "Use the front and back cameras at the same time so the story and your reaction stay together.",
    },
    {
        title: "Real-time reactions",
        description: "Capture what is happening and how you react in a single video, without cutting between clips.",
    },
    {
        title: "Background removal",
        description: "Keep the focus on you with clean background removal for reaction-style videos.",
    },
    {
        title: "Two angles in one video",
        description: "Show the moment from one camera and your expression from the other in one ready-to-share take.",
    },
    {
        title: "Ready for social platforms",
        description: "Prepare videos for TikTok, Instagram Reels, YouTube Shorts, and other vertical-first channels.",
    },
    {
        title: "High-quality export",
        description: "Export finished videos in high quality so they are ready to post without extra editing steps.",
    },
];

const useCases = [
    {
        title: "Record everything. Including your reaction.",
        description: "DuoTake records with the front and back cameras at once, showing what is happening and how you react in a single video.",
    },
    {
        title: "Show everything",
        description: "Stop recording only half the story. Capture the moment, your point of view, and your reaction together.",
    },
];

const faq = [
    {
        question: "What is DuoTake?",
        answer: "DuoTake is a dual-camera video app for recording with the front and back cameras at the same time. It helps you capture the moment and your reaction in a single video, without cutting between clips.",
    },
    {
        question: "Who is DuoTake for?",
        answer: "DuoTake is perfect for creators, reviews, reacts, commentary, behind-the-scenes videos, and anyone who wants to show what is happening and how they react at the same time.",
    },
    {
        question: "Is DuoTake ready for TikTok, Reels, and Shorts?",
        answer: "Yes. DuoTake includes social-ready formats so you can prepare videos for TikTok, Instagram Reels, YouTube Shorts, and other creator platforms.",
    },
    {
        question: "Does DuoTake support background removal?",
        answer: "Yes. DuoTake includes background removal to help keep your reaction clean, focused, and easier to place over the moment you are recording.",
    },
    {
        question: "Does DuoTake work offline?",
        answer: "Yes. Core capture and media processing are designed to work directly on your device. Features that depend on Apple services, such as purchase validation or saving to your photo library, may require the corresponding system permissions.",
    },
    {
        question: "How do I restore my purchase?",
        answer: "If you already unlocked DuoTake premium features, tap <em>Restore Purchases</em> and the app will ask Apple to verify your previous purchase using the same Apple ID — with no extra charge.",
    },
];
---

<AppTemplate
    title={title}
    appName={appName}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    testFlightUrl={testFlightUrl}
    socialImage={socialImage}
    socialImageAlt={socialImageAlt}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="en"
    applicationCategory="MultimediaApplication"
/>

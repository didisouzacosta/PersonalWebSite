    {
        url: {
            en: "duotake/screenshots/en/frame-6.png",
            ptBr: "duotake/screenshots/ptBR/frame-6.png",
        },
        alt: "DuoTake live reaction recording at a stadium with a reaction camera overlay.",
        caption: "Appear alongside the moment with a live reaction overlay.",
    },
];

const facts = [
    { label: "Platform", value: "iPhone" },
    { label: "Version", value: "1.2.0" },
    { label: "Best for", value: "Creators, reviews, reacts" },
    { label: "Output", value: "TikTok, Reels, Shorts" },
];

const features = [
    {
        title: "Dual-camera recording",
        description: "Use the front and back cameras at the same time so the story and your reaction stay together.",
    },
    {
        title: "Real-time reactions",
        description: "Capture what is happening and how you react in a single video, without cutting between clips.",
    },
    {
        title: "Premium Teleprompter",
        description: "Write or paste a script, follow it on screen while recording, and keep presentations, reviews, tutorials, and vlogs clearer.",
    },
    {
        title: "Cover layout",
        description: "Highlight one camera full-screen while placing the second camera as an overlay for more creative reaction videos.",
    },
    {
        title: "CropOut background removal",
        description: "Remove the background around your face to better highlight your reaction in the composition.",
    },
    {
        title: "Two angles in one video",
        description: "Show the moment from one camera and your expression from the other in one ready-to-share take.",
    },
    {
        title: "Ready for social platforms",
        description: "Prepare videos for TikTok, Instagram Reels, YouTube Shorts, and other vertical-first channels.",
    },
    {
        title: "High-quality export",
        description: "Export finished videos in high quality so they are ready to post without extra editing steps.",
    },
];

const useCases = [
    {
        title: "Record everything. Including your reaction.",
        description: "DuoTake records with the front and rear cameras at once, showing what is happening and how you react in a single video.",
    },
    {
        title: "Stay on script",
        description: "Use the premium Teleprompter for presentations, reviews, tutorials, vlogs, and scripted reactions without looking away from the camera.",
    },
];

const faq = [
    {
        question: "What is DuoTake?",
        answer: "DuoTake is a dual-camera video app for recording with the front and rear cameras at the same time. It helps you capture the moment, your voice, your script, and your reaction in one composed video.",
    },
    {
        question: "Who is DuoTake for?",
        answer: "DuoTake is made for creators, product reviews, reactions, commentary, tutorials, vlogs, events, travel videos, and anyone who wants to show the moment and their reaction at the same time.",
    },
    {
        question: "Is DuoTake ready for TikTok, Reels, and Shorts?",
        answer: "Yes. DuoTake includes social-ready formats so you can prepare videos for TikTok, Instagram Reels, YouTube Shorts, and other creator platforms.",
    },
    {
        question: "Does DuoTake support background removal?",
        answer: "Yes. DuoTake includes CropOut background removal to help keep your reaction clean, focused, and easier to place over the moment you are recording.",
    },
    {
        question: "Does DuoTake include a Teleprompter?",
        answer: "Yes. Premium users can use the Teleprompter to write or paste a script, follow the text during capture, and record presentations, reviews, tutorials, vlogs, and reactions more naturally.",
    },
    {
        question: "Does DuoTake work offline?",
        answer: "Yes. Core capture and media processing are designed to work directly on your device. Features that depend on Apple services, such as purchase validation or saving to your photo library, may require the corresponding system permissions.",
    },
    {
        question: "How do I restore my purchase?",
        answer: "If you already unlocked DuoTake premium features, tap <em>Restore Purchases</em> and the app will ask Apple to verify your previous purchase using the same Apple ID — with no extra charge.",
    },
];
---

<AppTemplate
    title={title}
    appId={appId}
    appStoreUrl={appStoreUrl}
    appName={appName}
    pageTitle={pageTitle}
    metas={metas}
    favicon={favicon}
    appIcon={appIcon}
    socialImage={socialImage}
    socialImageAlt={socialImageAlt}
    description={description}
    screenshots={screenshots}
    faq={faq}
    facts={facts}
    features={features}
    useCases={useCases}
    primaryKeyword={primaryKeyword}
    secondaryKeywords={secondaryKeywords}
    lang="en"
    applicationCategory="MultimediaApplication"
/>

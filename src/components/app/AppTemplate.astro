---
import Layout from "../../layouts/Layout.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import {
    appAssetBaseUrl,
    breadcrumbJsonLd,
    getAppAlternates,
    softwareApplicationJsonLd,
    type SeoLanguage,
} from "../../core/seo";

interface AppFeature {
    title: string;
    description: string;
}

interface AppUseCase {
    title: string;
    description: string;
}

interface AppFact {
    label: string;
    value: string;
}

interface AppTestimonial {
    quote: string;
    author: string;
    context?: string;
}

type LocalizedScreenshotUrl = string | {
    en: string;
    ptBr?: string;
    "pt-br"?: string;
};

interface AppScreenshot {
    url: LocalizedScreenshotUrl;
    alt: string;
    caption?: string;
}

interface Props {
    appId?: string,
    title: string,
    pageTitle?: string,
    appName?: string,
    favicon: string,
    appIcon: string,
    description: string,
    screenshots: AppScreenshot[],
    faq: { question: string, answer: string }[],
    metas: { name: string, content: string }[],
    lang?: string,
    applicationCategory?: string,
    features?: AppFeature[],
    useCases?: AppUseCase[],
    facts?: AppFact[],
    testimonials?: AppTestimonial[],
    primaryKeyword?: string,
    secondaryKeywords?: string[],
}

const {
    appId,
    title,
    pageTitle,
    appName,
    metas,
    favicon,
    appIcon,
    description,
    screenshots,
    faq,
    lang,
    applicationCategory = "MobileApplication",
    features = [],
    useCases = [],
    facts = [],
    testimonials = [],
    primaryKeyword,
    secondaryKeywords = [],
} = Astro.props;

const baseAssetsURL = 'https://pub-81dc0daed73f4a358469301b9b80f493.r2.dev/'
const currentPath = Astro.url.pathname;
const seoLanguage: SeoLanguage = lang === "pt-br" ? "pt-br" : "en";
const structuredAppName = appName ?? title.split(/[-|]/)[0].trim();
const legalBasePath = (currentPath.startsWith('/pt-br/')
    ? currentPath.replace('/pt-br', '')
    : currentPath).replace(/\/$/, '');
const resolveScreenshotUrl = (url: LocalizedScreenshotUrl, language: SeoLanguage) => {
    if (typeof url === "string") return url;

    return language === "pt-br"
        ? url.ptBr ?? url["pt-br"] ?? url.en
        : url.en;
};
const localizedScreenshots = screenshots.map((screenshot) => ({
    ...screenshot,
    url: resolveScreenshotUrl(screenshot.url, seoLanguage),
}));
const appJsonLd = softwareApplicationJsonLd({
    name: structuredAppName,
    description,
    path: currentPath,
    appIcon,
    screenshots: localizedScreenshots.map((screenshot) => screenshot.url),
    appId,
    language: seoLanguage,
    applicationCategory,
    featureList: features.map((feature) => feature.title),
    keywords: [primaryKeyword, ...secondaryKeywords].filter(Boolean) as string[],
});
const breadcrumbJson = breadcrumbJsonLd([
    { name: "Home", path: seoLanguage === "pt-br" ? "/pt-br/" : "/" },
    { name: structuredAppName, path: currentPath },
]);
---

<Layout
    title={pageTitle ?? title}
    favicon={favicon}
    description={description}
    metas={metas}
    lang={lang}
    canonicalPath={currentPath}
    alternateLocales={getAppAlternates(currentPath)}
    ogImage={`${appAssetBaseUrl}${appIcon}`}
    jsonLd={[appJsonLd, breadcrumbJson]}
>
    <main class="app-page">

        <header class="app-header">
            <div class="container app-header-inner">
                <img
                    src=`${baseAssetsURL}apps/${appIcon}`
                    alt={`${title} app icon`}
                    fetchpriority="high"
                    class="app-icon"
                    width="120"
                    height="120"
                />
                <h1 class="app-title">{title}</h1>
                <p class="app-subtitle">{description}</p>
                {appId && (
                    <a
                        href=`https://apps.apple.com/us/app/video-ai-art-generator-maker/${appId}?itscg=30200&itsct=apps_box_badge&mttnsubad=6450398697`
                        aria-label=`Download ${title} on the App Store`
                        target="_blank"
                        rel="noopener noreferrer"
                        class="app-store-link no-ext-icon"
                        data-analytics-event="app_store_clicked"
                        data-analytics-location="app-header"
                        data-analytics-label={structuredAppName}
                        data-analytics-project={structuredAppName.toLowerCase()}
                    >
                        <img
                            src="https://toolbox.marketingtools.apple.com/api/v2/badges/download-on-the-app-store/black/en-us?releaseDate=1687219200"
                            alt="Download on the App Store"
                            class="app-store-badge"
                            width="160"
                            height="54"
                        />
                    </a>
                )}
            </div>
        </header>

        {facts.length > 0 && (
            <section class="product-facts" aria-label={seoLanguage === "pt-br" ? "Resumo do app" : "App summary"}>
                <div class="container product-facts-inner">
                    {facts.map((fact) => (
                        <div class="product-fact">
                            <span>{fact.label}</span>
                            <strong>{fact.value}</strong>
                        </div>
                    ))}
                </div>
            </section>
        )}

        <section class="screenshots-section" aria-label="Screenshots">
            <ul class="screenshots">
                {
                    localizedScreenshots.map((screenshot, index) => (
                        <li>
                            <figure>
                                <img
                                    src=`${baseAssetsURL}apps/${screenshot.url}`
                                    alt={screenshot.alt}
                                    loading="lazy"
                                    data-analytics-ignore="true"
                                    data-analytics-event="screenshot_opened"
                                    data-analytics-location="app-screenshots"
                                    data-analytics-label={screenshot.alt}
                                    data-analytics-project={structuredAppName.toLowerCase()}
                                    data-lightbox-index={index}
                                />
                                {screenshot.caption && <figcaption>{screenshot.caption}</figcaption>}
                            </figure>
                        </li>
                    ))
                }
            </ul>
            <dialog id="screenshot-lightbox" aria-label="Screenshot preview">
                <button id="lightbox-close" aria-label="Close preview" data-analytics-ignore="true">&#x2715;</button>
                <button id="lightbox-prev" class="lightbox-nav lightbox-prev" aria-label="Previous screenshot" data-analytics-ignore="true">
                    <span aria-hidden="true">&#8249;</span>
                </button>
                <img id="lightbox-img" src="" alt="" />
                <button id="lightbox-next" class="lightbox-nav lightbox-next" aria-label="Next screenshot" data-analytics-ignore="true">
                    <span aria-hidden="true">&#8250;</span>
                </button>
            </dialog>
        </section>

        {features.length > 0 && (
            <section class="features-section section-sm" aria-labelledby="features-heading">
                <div class="container">
                    <h2 id="features-heading">{
                        seoLanguage === "pt-br" ? "Recursos principais" : "Key features"
                    }</h2>
                    <div class="feature-grid">
                        {features.map((feature) => (
                            <article class="feature-card">
                                <h3>{feature.title}</h3>
                                <p>{feature.description}</p>
                            </article>
                        ))}
                    </div>
                </div>
            </section>
        )}

        {useCases.length > 0 && (
            <section class="use-cases-section section-sm" aria-labelledby="use-cases-heading">
                <div class="container">
                    <h2 id="use-cases-heading">{
                        seoLanguage === "pt-br" ? "Ideal para" : "Best for"
                    }</h2>
                    <div class="use-case-list">
                        {useCases.map((useCase) => (
                            <article class="use-case-item">
                                <h3>{useCase.title}</h3>
                                <p>{useCase.description}</p>
                            </article>
                        ))}
                    </div>
                </div>
            </section>
        )}

        {testimonials.length > 0 && (
            <section class="testimonials-section section-sm" aria-labelledby="testimonials-heading">
                <div class="container">
                    <h2 id="testimonials-heading">{
                        seoLanguage === "pt-br" ? "O que usuários dizem" : "What users say"
                    }</h2>
                    <div class="testimonial-list">
                        {testimonials.map((testimonial) => (
                            <figure class="testimonial">
                                <blockquote>{testimonial.quote}</blockquote>
                                <figcaption>
                                    <strong>{testimonial.author}</strong>
                                    {testimonial.context && <span>{testimonial.context}</span>}
                                </figcaption>
                            </figure>
                        ))}
                    </div>
                </div>
            </section>
        )}

        <section class="faq-section section-sm" aria-labelledby="faq-heading">
            <div class="container">
                <h2 id="faq-heading" class="faq-heading">FAQ</h2>
                <FaqAccordion items={faq} />
            </div>
        </section>

        <footer class="app-footer">
            <div class="container">
                <nav aria-label="Legal links">
                    <a
                        href={`${legalBasePath}/terms-of-use`}
                        data-analytics-event="app_legal_link_clicked"
                        data-analytics-location="app-footer"
                        data-analytics-label="Terms of use"
                        data-analytics-project={structuredAppName.toLowerCase()}
                    >
                        Terms of use
                    </a>
                    <span aria-hidden="true">&bull;</span>
                    <a
                        href={`${legalBasePath}/privacy-policy`}
                        data-analytics-event="app_legal_link_clicked"
                        data-analytics-location="app-footer"
                        data-analytics-label="Privacy policy"
                        data-analytics-project={structuredAppName.toLowerCase()}
                    >
                        Privacy policy
                    </a>
                </nav>
            </div>
        </footer>
    </main>
</Layout>

<style>
    .app-page {
        display: flex;
        flex-direction: column;
        gap: 0;
        overflow-x: clip;
        background: var(--bg);
    }

    /* Header */
    .app-header {
        position: relative;
        padding: 124px 0 48px;
        text-align: center;
    }

    .app-header-inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
        width: 100%;
        max-width: 720px;
    }

    .app-icon {
        position: relative;
        z-index: 1;
        width: 120px;
        height: 120px;
        object-fit: cover;
    }

    .app-title {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: min(680px, 100%);
        font-size: clamp(40px, 6vw, 64px);
        font-weight: 720;
        letter-spacing: -0.035em;
        line-height: 1.02;
        color: var(--text-primary);
        margin: 0;
        text-wrap: balance;
    }

    .app-subtitle {
        position: relative;
        z-index: 1;
        width: 100%;
        font-size: clamp(17px, 2vw, 20px);
        color: var(--text-secondary);
        max-width: 600px;
        margin: 0;
        line-height: 1.55;
        text-wrap: pretty;
    }

    .app-store-link {
        position: relative;
        z-index: 1;
        display: inline-flex;
        margin-top: 6px;
        transition: opacity 0.2s ease-out, transform 0.2s ease-out;
    }

    .app-store-link:hover {
        opacity: 0.75;
        transform: translateY(-1px);
    }

    .app-store-badge {
        height: 44px;
        width: auto;
    }

    /* Product facts */
    .product-facts {
        padding: 8px 0 40px;
        background: transparent;
    }

    .product-facts-inner {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 0;
        width: calc(100% - 64px);
        max-width: 916px;
        padding: 0;
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 22px;
        background: color-mix(in srgb, var(--bg) 94%, var(--bg-secondary));
    }

    .product-fact {
        position: relative;
        padding: 24px 18px;
        text-align: center;
    }

    .product-fact + .product-fact {
        border-left: 1px solid var(--border);
    }

    .product-fact span {
        display: block;
        color: var(--text-tertiary);
        font-size: 12px;
        font-weight: 650;
        line-height: 1.4;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .product-fact strong {
        color: var(--text-primary);
        font-size: 16px;
        font-weight: 650;
        line-height: 1.4;
    }

    /* Screenshots */
    .screenshots-section {
        position: relative;
        padding: 64px 0;
        background: var(--bg-secondary);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
    }

    .screenshots {
        display: grid;
        grid-auto-flow: column;
        grid-auto-columns: minmax(216px, 252px);
        justify-content: center;
        gap: 18px;
        max-width: 100%;
        margin: 0;
        overflow-x: auto;
        overscroll-behavior-x: contain;
        list-style: none;
        padding: 10px max(32px, calc((100vw - 1180px) / 2 + 32px)) 22px;
        scroll-padding-inline: max(32px, calc((100vw - 1180px) / 2 + 32px));
        scroll-snap-type: x proximity;
        scrollbar-width: none;
    }

    .screenshots::-webkit-scrollbar {
        display: none;
    }

    .screenshots li {
        scroll-snap-align: center;
    }

    .screenshots figure {
        margin: 0;
    }

    .screenshots figure img {
        width: 100%;
        border: 1px solid color-mix(in srgb, var(--border-strong) 48%, transparent);
        border-radius: 24px;
        cursor: pointer;
        box-shadow: 0 10px 28px color-mix(in srgb, var(--text-primary) 7%, transparent);
        transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
    }

    .screenshots figure img:hover {
        border-color: var(--border-strong);
        transform: translateY(-3px);
        box-shadow: 0 14px 34px color-mix(in srgb, var(--text-primary) 9%, transparent);
    }

    .screenshots figcaption {
        color: var(--text-tertiary);
        font-size: 12px;
        font-weight: 500;
        line-height: 1.45;
        margin: 14px auto 0;
        max-width: 220px;
        text-align: center;
    }

    /* Product sections */
    .use-cases-section {
        background: var(--bg-secondary);
    }

    .features-section h2,
    .use-cases-section h2,
    .testimonials-section h2 {
        color: var(--text-primary);
        font-size: clamp(28px, 3vw, 38px);
        font-weight: 720;
        letter-spacing: -0.03em;
        margin: 0 0 28px;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 16px;
    }

    .feature-card,
    .use-case-item,
    .testimonial {
        border-radius: 22px;
        padding: 26px;
        background: color-mix(in srgb, var(--bg) 96%, var(--bg-secondary));
    }

    .feature-card,
    .use-case-item {
        border: 1px solid var(--border);
        transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease, background-color 220ms ease;
    }

    .feature-card:hover,
    .use-case-item:hover {
        border-color: var(--border-strong);
        background: color-mix(in srgb, var(--bg) 92%, var(--bg-secondary));
        box-shadow: 0 8px 22px color-mix(in srgb, var(--text-primary) 5%, transparent);
        transform: translateY(-2px);
    }

    .feature-card h3,
    .use-case-item h3 {
        color: var(--text-primary);
        font-size: 17px;
        font-weight: 700;
        letter-spacing: -0.01em;
        line-height: 1.2;
        margin: 0 0 10px;
    }

    .feature-card p,
    .use-case-item p,
    .testimonial blockquote {
        color: var(--text-secondary);
        font-size: 15px;
        line-height: 1.6;
        margin: 0;
    }

    .use-case-list,
    .testimonial-list {
        display: grid;
        gap: 14px;
    }

    .testimonial {
        border: 1px solid var(--border);
        margin: 0;
    }

    .testimonial figcaption {
        display: flex;
        flex-direction: column;
        gap: 4px;
        color: var(--text-tertiary);
        margin-top: 16px;
    }

    .testimonial figcaption strong {
        color: var(--text-primary);
    }

    /* Lightbox */
    #screenshot-lightbox {
        position: fixed;
        inset: 50% auto auto 50%;
        padding: 0;
        margin: 0;
        border: none;
        border-radius: 20px;
        background: transparent;
        max-width: 92vw;
        max-height: 92svh;
        overflow: visible;
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.96);
        transition: opacity 220ms ease, transform 220ms ease;
    }

    #screenshot-lightbox[open] {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }

    #screenshot-lightbox::backdrop {
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(6px);
    }

    #lightbox-img {
        display: block;
        max-width: 90vw;
        max-height: 90vh;
        border-radius: 20px;
        object-fit: contain;
        transform-origin: center;
        animation: lightbox-image-zoom 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
        box-shadow: 0 28px 80px rgba(0, 0, 0, 0.34);
    }

    #lightbox-img.is-changing {
        animation: lightbox-image-zoom 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    #lightbox-close {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(0, 0, 0, 0.55);
        color: white;
        border: none;
        border-radius: 50%;
        width: 34px;
        height: 34px;
        font-size: 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
    }

    .lightbox-nav {
        position: absolute;
        top: 50%;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border: none;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.5);
        color: white;
        cursor: pointer;
        transform: translateY(-50%);
        transition: background 180ms ease, opacity 180ms ease, transform 180ms ease;
    }

    .lightbox-nav span {
        display: block;
        font-size: 34px;
        line-height: 1;
        transform: translateY(-1px);
    }

    .lightbox-prev {
        left: -58px;
    }

    .lightbox-next {
        right: -58px;
    }

    .lightbox-nav:hover,
    .lightbox-nav:focus-visible,
    #lightbox-close:hover,
    #lightbox-close:focus-visible {
        background: rgba(0, 0, 0, 0.72);
        opacity: 1;
    }

    .lightbox-nav:disabled {
        cursor: default;
        opacity: 0.28;
        pointer-events: none;
    }

    .lightbox-nav:focus-visible,
    #lightbox-close:focus-visible {
        outline: 2px solid white;
        outline-offset: 3px;
    }

    @keyframes lightbox-image-zoom {
        from {
            opacity: 0;
            transform: scale(0.94);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* FAQ */
    .faq-section {
        background: var(--bg);
    }

    .faq-heading {
        font-size: clamp(28px, 3vw, 38px);
        font-weight: 720;
        letter-spacing: -0.03em;
        color: var(--text-primary);
        margin-bottom: 28px;
    }

    /* Footer */
    .app-footer {
        margin-bottom: 24px;
        padding: 32px 0 8px;
    }

    .app-footer nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        font-size: 14px;
        color: var(--text-tertiary);
        text-align: center;
    }

    .app-footer nav a {
        color: var(--text-secondary);
        transition: color 0.2s ease-out;
    }

    .app-footer nav a:hover {
        color: var(--text-primary);
        opacity: 1;
    }

    @media only screen and (max-width: 768px) {
        .app-header {
            padding: 104px 0 34px;
        }

        .app-icon {
            width: 96px;
            height: 96px;
        }

        .app-title {
            font-size: clamp(32px, 9.5vw, 40px);
            letter-spacing: -0.03em;
            line-height: 1.06;
            max-width: 100%;
        }

        .app-subtitle {
            max-width: 304px;
            font-size: 16px;
            line-height: 1.55;
        }

        .product-facts {
            padding-bottom: 30px;
        }

        .product-facts-inner {
            grid-template-columns: 1fr;
            width: calc(100% - 48px);
            border-radius: 20px;
        }

        .product-fact + .product-fact {
            border-top: 1px solid var(--border);
            border-left: 0;
        }

        .screenshots-section {
            padding: 48px 0;
        }

        .screenshots {
            grid-auto-columns: minmax(206px, 72vw);
            justify-content: start;
            gap: 14px;
            padding-inline: 24px;
            scroll-padding-inline: 24px;
        }

        .product-fact {
            padding: 20px 12px;
        }

        .feature-grid {
            grid-template-columns: 1fr;
        }

        .lightbox-prev {
            left: 10px;
        }

        .lightbox-next {
            right: 10px;
        }

        .lightbox-nav {
            width: 40px;
            height: 40px;
        }
    }
</style>

<script>
    import { trackAnalyticsEvent } from "../../core/analytics";

    const dialog = document.getElementById('screenshot-lightbox') as HTMLDialogElement;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement | null;
    const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement | null;
    const screenshotImages = Array.from(document.querySelectorAll<HTMLImageElement>('.screenshots figure img'));
    let currentScreenshotIndex = 0;
    let savedScrollPosition = { x: 0, y: 0 };

    const restoreScrollPosition = () => {
        window.scrollTo(savedScrollPosition.x, savedScrollPosition.y);
    };

    const updateLightboxControls = () => {
        if (prevBtn) prevBtn.disabled = currentScreenshotIndex === 0;
        if (nextBtn) nextBtn.disabled = currentScreenshotIndex === screenshotImages.length - 1;
    };

    const showScreenshot = (index: number, source: string) => {
        const image = screenshotImages[index];
        if (!image) return;

        currentScreenshotIndex = index;
        updateLightboxControls();
        lightboxImg.classList.remove("is-changing");
        lightboxImg.src = image.src;
        lightboxImg.alt = image.alt;
        void lightboxImg.offsetWidth;
        lightboxImg.classList.add("is-changing");

        if (source !== "open") {
            trackAnalyticsEvent("screenshot_navigated", {
                label: image.alt,
                location: "app-screenshots",
                source,
                project_slug: image.dataset.analyticsProject,
            });
        }
    };

    const moveScreenshot = (direction: 1 | -1, source: string) => {
        if (screenshotImages.length === 0) return;

        const nextIndex = currentScreenshotIndex + direction;
        if (nextIndex < 0 || nextIndex >= screenshotImages.length) return;

        showScreenshot(nextIndex, source);
        restoreScrollPosition();
    };

    screenshotImages.forEach((img, index) => {
        img.addEventListener('click', () => {
            const image = img as HTMLImageElement;
            savedScrollPosition = { x: window.scrollX, y: window.scrollY };
            showScreenshot(index, "open");
            dialog.showModal();
            closeBtn?.focus({ preventScroll: true });
            requestAnimationFrame(restoreScrollPosition);

            trackAnalyticsEvent("screenshot_opened", {
                label: image.alt,
                location: "app-screenshots",
                project_slug: image.dataset.analyticsProject,
            });
        });
    });

    const closeLightbox = (source: string) => {
        dialog.close();
        restoreScrollPosition();
        trackAnalyticsEvent("screenshot_closed", {
            source,
            location: "app-screenshots",
        });
    };

    closeBtn?.addEventListener('click', () => closeLightbox("close-button"));
    prevBtn?.addEventListener('click', () => moveScreenshot(-1, "previous-button"));
    nextBtn?.addEventListener('click', () => moveScreenshot(1, "next-button"));

    dialog.addEventListener('click', (e) => {
        if (e.target === dialog) closeLightbox("backdrop");
    });

    dialog.addEventListener('cancel', (e) => {
        e.preventDefault();
        closeLightbox("escape");
    });

    dialog.addEventListener('keydown', (e) => {
        if (e.key === "ArrowLeft") {
            e.preventDefault();
            moveScreenshot(-1, "keyboard");
        }

        if (e.key === "ArrowRight") {
            e.preventDefault();
            moveScreenshot(1, "keyboard");
        }
    });

    lightboxImg.addEventListener("animationend", () => {
        lightboxImg.classList.remove("is-changing");
    });
</script>

---
import type { AnalyticsPageContext } from "../core/analyticsContext";

interface Props {
    context: AnalyticsPageContext;
}

const { context } = Astro.props;
---

<script
    is:inline
    set:html={`
        window.__SITE_ANALYTICS_CONTEXT__ = ${JSON.stringify(context)};
        window.__SITE_ANALYTICS_ORIGINAL_TITLE__ = document.title;
    `}
/>

<script>
    import { initializeAnalytics, loadAnalyticsProvider } from "../core/analytics";

    const consentKey = "analytics-consent";

    function getAnalyticsConsent() {
        try {
            return window.localStorage.getItem(consentKey);
        } catch {
            return null;
        }
    }

    function enableAnalytics() {
        loadAnalyticsProvider();
        initializeAnalytics();
    }

    if (getAnalyticsConsent() === "accepted") {
        enableAnalytics();
    }

    window.addEventListener("analytics-consent-changed", (event) => {
        if (!(event instanceof CustomEvent)) return;
        if (event.detail?.consent === "accepted") {
            enableAnalytics();
        }
    });
</script>

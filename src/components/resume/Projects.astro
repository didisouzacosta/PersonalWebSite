---
import { getProjectCards, type ProjectLanguage } from "../../core/projects";

interface Props {
    lang?: ProjectLanguage;
}

const { lang = "en" } = Astro.props;
const enabledApps = getProjectCards(lang);
---

{
    enabledApps.length > 0 && (
        <ul class="projects-grid" role="list">
            {
                enabledApps.map((app) => (
                    <li>
                        <article class="project-card">
                            <a
                                href={app.url}
                                target={app.target}
                                rel={app.target === "_blank" ? "noopener noreferrer" : undefined}
                                aria-label={`${app.name} — ${app.description}`}
                                class={`card-link${app.target === "_blank" ? " no-ext-icon" : ""}`}
                                data-analytics-location="projects-section"
                                data-analytics-label={app.name}
                                data-analytics-project={app.name.toLowerCase().replace(/\s+/g, '-')}
                            >
                                <img
                                    src={app.imageUrl}
                                    alt={lang === "pt-br" ? `Ícone do app ${app.name}` : `${app.name} app icon`}
                                    loading="lazy"
                                    decoding="async"
                                    class="app-icon"
                                    width="64"
                                    height="64"
                                />
                                <div class="card-info">
                                    <h3 class="app-name">
                                        {app.name}
                                        {app.target === "_blank" && (
                                            <span class="ext-icon" aria-label="opens in new tab">↗</span>
                                        )}
                                    </h3>
                                    <p class="app-description">{app.description}</p>
                                    <div class="tags" role="list">
                                        {app.tags.map((tag) => (
                                            <span role="listitem" class="tag">{tag}</span>
                                        ))}
                                    </div>
                                </div>
                            </a>
                        </article>
                    </li>
                ))
            }
        </ul>
    )
}

<style>
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin-top: 40px;
    }

    .project-card {
        background-color: var(--bg-secondary);
        border-radius: var(--radius-card);
        transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;
    }

    .project-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-hover);
    }

    .card-link {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px;
        opacity: 1;
    }

    .card-link:hover {
        opacity: 1;
    }

    .app-icon {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .card-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
    }

    .app-name {
        font-size: 16px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text-primary);
    }

    .ext-icon {
        font-size: 0.65em;
        opacity: 0.45;
        vertical-align: super;
        margin-left: 2px;
        transition: opacity 0.2s ease-out;
    }

    .card-link:hover .ext-icon {
        opacity: 0.8;
    }

    .app-description {
        font-size: 13px;
        color: var(--text-secondary);
        margin-bottom: 6px;
    }

    @media only screen and (max-width: 600px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

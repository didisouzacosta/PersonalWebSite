---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import type { HomepageContent } from "../../core/homepage";
import { getProjectCards, hasEnabledProjects } from "../../core/projects";

import Projects from "./Projects.astro";

interface Props {
    content: HomepageContent;
}

const { content } = Astro.props;
const hasProjects = hasEnabledProjects();
const heroApps = getProjectCards(content.lang);
const visibleOrbitRadii = [72, 116.5, 188.5, 44.5];

const fallbackOrbitItems = heroApps.map((app, index, apps) => {
    const shellCount = Math.min(4, Math.max(2, Math.ceil((apps.length || 1) / 4)));
    const shell = index % shellCount;
    const positionInShell = Math.floor(index / shellCount);
    const shellTotal = Math.ceil((apps.length - shell) / shellCount);
    const angle = (positionInShell * (360 / shellTotal) + shell * 72) % 360;
    const radius = visibleOrbitRadii[shell];
    const duration = 40 + shell * 16;
    const size = 54 + ((index * 9) % 22);
    const depth = 0.22 + shell * 0.12;
    const tilt = (index % 2 === 0 ? -1 : 1) * (3 + (index % 4));
    const direction = shell % 2 === 0 ? "normal" : "reverse";

    return {
        app,
        style: [
            `--orbit-start: ${angle.toFixed(2)}deg`,
            `--orbit-start-inverse: ${(-angle).toFixed(2)}deg`,
            `--orbit-radius: ${radius.toFixed(2)}px`,
            `--orbit-duration: ${duration.toFixed(2)}s`,
            `--orbit-direction: ${direction}`,
            `--planet-size: ${size.toFixed(2)}px`,
            `--planet-depth: ${depth.toFixed(2)}`,
            `--planet-tilt: ${tilt.toFixed(2)}deg`,
        ].join("; "),
    };
});
---

<nav class="home-nav" aria-label="Page sections">
	<a href="#about">{content.aboutTitle}</a>
	{hasProjects && (
		<>
			<span class="nav-sep" aria-hidden="true">•</span>
			<a href="#projects">{content.projectsTitle}</a>
		</>
	)}
</nav>

<main>
	<section id="hero" aria-label="Introduction" class="hero-section">
		<span class="space-stars" aria-hidden="true"></span>
		<span class="shooting-stars" aria-hidden="true">
			<span class="shooting-star shooting-star-1"></span>
			<span class="shooting-star shooting-star-2"></span>
			<span class="shooting-star shooting-star-3"></span>
		</span>
		<div class="container hero-inner">
			<div class="hero-copy">
				<Image
					src="https://avatars.githubusercontent.com/u/11352503?v=4"
					alt="Adriano Souza Costa"
					width="140"
					height="140"
					loading="eager"
					class="avatar fade-in"
				/>

				<h1 class="hero-name fade-in" data-delay="1">Adriano<br />Souza Costa</h1>

				<p class="hero-title fade-in" data-delay="1">{content.role.replace(" • ", " \n")}</p>

				<div class="hero-cta fade-in" data-delay="2">
					<a href={content.resumeLink} class="btn-primary">
						<span>{content.resumeLabel}</span>
						<Icon name="right-arrow" width={13} height={13} />
					</a>
				</div>

				<nav class="social-links fade-in" data-delay="3" aria-label="Social links">
					<a
						href="https://x.com/didisouzacosta"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="X (Twitter)"
						class="no-ext-icon"
					>
						<Icon name="x" class="social-icon" />
					</a>
					<a
						href="https://github.com/didisouzacosta"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="GitHub"
						class="no-ext-icon"
					>
						<Icon name="github" class="social-icon" />
					</a>
					<a
						href="https://www.linkedin.com/in/adrianosouzacosta"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn"
						class="no-ext-icon"
					>
						<Icon name="linkedin" class="social-icon" />
					</a>
				</nav>
			</div>

			<div class="hero-visual fade-in" data-delay="2" aria-hidden="true">
				<div class="app-icon-stage">
					<span class="fibonacci-ring ring-34"></span>
					<span class="fibonacci-ring ring-55"></span>
					<span class="fibonacci-ring ring-89"></span>
					<span class="fibonacci-ring ring-144"></span>
					<span class="fibonacci-axis axis-horizontal"></span>
					<span class="fibonacci-axis axis-vertical"></span>
					<span class="fibonacci-axis axis-golden-positive"></span>
					<span class="fibonacci-axis axis-golden-negative"></span>
					<svg class="apple-core" viewBox="0 0 384 512" aria-hidden="true">
						<path
							fill="currentColor"
							d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5c0 26.2 4.8 53.3 14.4 81.2 12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9ZM262.1 104.5c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3Z"
						/>
					</svg>
					{
						fallbackOrbitItems.map(({ app, style }) => (
							<span class="hero-app-orbit" data-hero-orbit-item style={style}>
								<span class="hero-app-planet">
									<img
										src={app.imageUrl}
										alt=""
										loading="eager"
										width="84"
										height="84"
										class="hero-app-icon"
									/>
								</span>
							</span>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section id="about" aria-label="About me" class="section about-section fade-in">
		<div class="container">
			<h2 class="section-title">{content.aboutTitle}</h2>
			<p class="bio">{content.bio}</p>
			<div class="skills tags" role="list" aria-label="Technical skills">
				{content.skills.map((skill) => (
					<span role="listitem" class="tag">{skill}</span>
				))}
			</div>
		</div>
	</section>

	{hasProjects && (
		<section id="projects" aria-label="Projects" class="section projects-section fade-in">
			<div class="container">
				<h2 class="section-title">{content.projectsTitle}</h2>
				<Projects lang={content.lang} />
			</div>
		</section>
	)}
</main>

<style>
	/* Hero */
	.hero-section {
		min-height: 100svh;
		display: flex;
		align-items: center;
		position: relative;
		overflow: hidden;
		isolation: isolate;
		--space-star: rgba(29, 29, 31, 0.18);
		--space-star-soft: rgba(29, 29, 31, 0.08);
		--space-arc: rgba(0, 0, 0, 0.07);
		--space-arc-strong: rgba(0, 0, 0, 0.11);
		--space-horizon: rgba(44, 80, 140, 0.08);
		--comet-core: rgba(29, 29, 31, 0.22);
		--comet-tail: rgba(44, 80, 140, 0.18);
	}

	.hero-section::before {
		content: "";
		position: absolute;
		inset: 0;
		z-index: -3;
		background:
			radial-gradient(ellipse 64% 46% at 76% 45%, var(--space-horizon), transparent 68%),
			linear-gradient(115deg, transparent 0 34%, var(--bg-secondary) 34% 34.12%, transparent 34.12%),
			linear-gradient(180deg, transparent 0%, color-mix(in srgb, var(--bg-secondary) 76%, transparent) 100%);
		opacity: 0.78;
	}

	.hero-section::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: -2;
		background-image:
			linear-gradient(var(--border) 1px, transparent 1px),
			linear-gradient(90deg, var(--border) 1px, transparent 1px);
		background-size:
			56px 56px,
			56px 56px;
		background-position:
			0 0,
			0 0;
		mask-image: linear-gradient(90deg, transparent 0%, black 46%, black 74%, transparent 100%);
		opacity: 0.24;
	}

	:global([data-theme="dark"]) .hero-section {
		--space-star: rgba(245, 245, 247, 0.34);
		--space-star-soft: rgba(245, 245, 247, 0.14);
		--space-arc: rgba(255, 255, 255, 0.09);
		--space-arc-strong: rgba(255, 255, 255, 0.16);
		--space-horizon: rgba(84, 136, 200, 0.16);
		--comet-core: rgba(245, 245, 247, 0.72);
		--comet-tail: rgba(110, 170, 255, 0.32);
	}

	.space-stars,
	.space-stars::before,
	.space-stars::after {
		position: absolute;
		inset: 0;
		display: block;
		pointer-events: none;
	}

	.space-stars {
		z-index: -1;
		mask-image: linear-gradient(90deg, transparent 0%, black 24%, black 86%, transparent 100%);
	}

	.space-stars::before,
	.space-stars::after {
		content: "";
		background-repeat: repeat;
		will-change: opacity, filter;
	}

	.space-stars::before {
		background-image:
			radial-gradient(circle at 16% 18%, var(--space-star) 0 1px, transparent 1.35px),
			radial-gradient(circle at 42% 26%, var(--space-star-soft) 0 1px, transparent 1.3px),
			radial-gradient(circle at 68% 16%, var(--space-star) 0 1px, transparent 1.35px),
			radial-gradient(circle at 78% 62%, var(--space-star-soft) 0 1px, transparent 1.3px),
			radial-gradient(circle at 92% 34%, var(--space-star) 0 1px, transparent 1.35px);
		background-size: 260px 260px, 310px 310px, 230px 230px, 290px 290px, 340px 340px;
		background-position: 0 0, 82px 46px, 34px 118px, 140px 10px, 220px 90px;
		animation: star-twinkle-primary 7.5s ease-in-out infinite;
		opacity: 0.9;
	}

	.space-stars::after {
		background-image:
			radial-gradient(circle at 8% 74%, var(--space-star-soft) 0 1px, transparent 1.25px),
			radial-gradient(circle at 28% 52%, var(--space-star) 0 1px, transparent 1.35px),
			radial-gradient(circle at 58% 82%, var(--space-star-soft) 0 1px, transparent 1.25px),
			radial-gradient(circle at 86% 48%, var(--space-star) 0 1px, transparent 1.35px);
		background-size: 360px 360px, 280px 280px, 420px 420px, 330px 330px;
		background-position: 44px 20px, 160px 82px, 10px 150px, 220px 26px;
		animation: star-twinkle-secondary 11s ease-in-out infinite;
		opacity: 0.52;
	}

	.shooting-stars,
	.shooting-star,
	.shooting-star::before,
	.shooting-star::after {
		position: absolute;
		display: block;
		pointer-events: none;
	}

	.shooting-stars {
		inset: 0;
		z-index: -1;
		overflow: hidden;
		mask-image: linear-gradient(90deg, transparent 0%, black 26%, black 92%, transparent 100%);
	}

	.shooting-star {
		--comet-width: 118px;
		--comet-angle: -22deg;
		--comet-start: -90px;
		--comet-end: 210px;
		width: var(--comet-width);
		height: 9px;
		opacity: 0;
		transform: rotate(var(--comet-angle)) translate3d(var(--comet-start), 0, 0);
		transform-origin: 100% 50%;
		will-change: opacity, transform, filter;
	}

	.shooting-star::before,
	.shooting-star::after {
		content: "";
	}

	.shooting-star::before {
		top: 4px;
		right: 2px;
		width: 100%;
		height: 1px;
		border-radius: 999px;
		background:
			linear-gradient(90deg, transparent 0%, color-mix(in srgb, var(--comet-tail) 18%, transparent) 34%, var(--comet-tail) 74%, var(--comet-core) 100%);
		filter: blur(0.2px);
	}

	.shooting-star::after {
		top: 2.5px;
		right: 0;
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: var(--comet-core);
		box-shadow:
			0 0 8px var(--comet-tail),
			0 0 18px color-mix(in srgb, var(--comet-tail) 70%, transparent);
	}

	.shooting-star-1 {
		top: 18%;
		left: 22%;
		animation: comet-glide 12s cubic-bezier(0.22, 0.64, 0.24, 1) -9s infinite;
	}

	.shooting-star-2 {
		top: 52%;
		left: 70%;
		--comet-width: 86px;
		--comet-angle: -18deg;
		--comet-start: -64px;
		--comet-end: 160px;
		animation: comet-glide 17s cubic-bezier(0.22, 0.64, 0.24, 1) -5s infinite;
	}

	.shooting-star-3 {
		top: 74%;
		left: 42%;
		--comet-width: 104px;
		--comet-angle: -24deg;
		--comet-start: -72px;
		--comet-end: 180px;
		animation: comet-glide 21s cubic-bezier(0.22, 0.64, 0.24, 1) -14s infinite;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: minmax(0, 560px) minmax(280px, 1fr);
		align-items: center;
		gap: clamp(40px, 6vw, 84px);
		padding-top: 80px;
		padding-bottom: 80px;
		position: relative;
		width: 100%;
	}

	.hero-inner::before,
	.hero-inner::after {
		content: "";
		position: absolute;
		pointer-events: none;
		border: 1px solid var(--space-arc);
		border-radius: 50%;
		z-index: -1;
	}

	.hero-inner::before {
		top: 4%;
		right: -24%;
		width: min(740px, 74vw);
		aspect-ratio: 1;
		opacity: 0.78;
		transform: rotate(-24deg) scaleY(0.56);
	}

	.hero-inner::after {
		top: 17%;
		right: -7%;
		width: min(500px, 50vw);
		aspect-ratio: 1;
		border-color: var(--space-arc-strong);
		opacity: 0.42;
		transform: rotate(18deg) scaleY(0.48);
	}

	.hero-copy {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.avatar {
		width: 88px;
		height: 88px;
		border-radius: 50%;
		object-fit: cover;
		margin-bottom: 34px;
		border: 1px solid var(--border-strong);
		box-shadow: 0 18px 50px rgba(0, 0, 0, 0.14);
	}

	.hero-name {
		font-size: clamp(54px, 8vw, 86px);
		font-weight: 700;
		letter-spacing: -0.04em;
		line-height: 1.02;
		color: var(--text-primary);
		margin-bottom: 16px;
	}

	.hero-title {
		font-size: clamp(20px, 3vw, 28px);
		font-weight: 400;
		color: var(--text-secondary);
		letter-spacing: -0.01em;
		white-space: pre-line;
		margin-bottom: 34px;
	}

	.hero-cta {
		margin-bottom: 34px;
	}

	.btn-primary {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 9px;
		background-color: var(--text-primary);
		color: var(--bg);
		font-size: 16px;
		font-weight: 600;
		line-height: 1;
		min-height: 48px;
		padding: 0 24px;
		border-radius: 980px;
		box-shadow: 0 14px 34px rgba(0, 0, 0, 0.18);
		overflow: hidden;
		transition: box-shadow 0.2s ease-out, transform 0.2s ease-out;
	}

	.btn-primary::before {
		content: "";
		position: absolute;
		inset: 1px;
		border-radius: inherit;
		background: linear-gradient(120deg, transparent 0 24%, rgba(255, 255, 255, 0.26) 42%, transparent 60% 100%);
		transform: translateX(-120%);
		transition: transform 0.6s ease-out;
	}

	.btn-primary span,
	.btn-primary svg {
		position: relative;
		z-index: 1;
	}

	.btn-primary:hover {
		opacity: 1;
		transform: translateY(-2px);
		box-shadow: 0 18px 44px rgba(0, 0, 0, 0.22);
	}

	.btn-primary:hover::before {
		transform: translateX(120%);
	}

	.btn-primary:focus-visible {
		outline: 2px solid var(--text-primary);
		outline-offset: 4px;
	}

	.hero-visual {
		min-height: 360px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.app-icon-stage {
		position: relative;
		width: clamp(280px, 32vw, 380px);
		aspect-ratio: 1;
		--cursor-x: 0px;
		--cursor-y: 0px;
		--stage-tilt-x: 0deg;
		--stage-tilt-y: 0deg;
		border-radius: 42px;
		animation: app-stage-float 7s ease-in-out infinite;
		transform: perspective(900px) rotateX(var(--stage-tilt-y)) rotateY(var(--stage-tilt-x));
		transform-style: preserve-3d;
		transition: transform 0.24s ease-out;
	}

	.fibonacci-ring,
	.fibonacci-axis {
		position: absolute;
		inset: 50%;
		display: block;
		pointer-events: none;
		z-index: 0;
	}

	.fibonacci-ring {
		width: calc(var(--ring-size) * 1px);
		height: calc(var(--ring-size) * 1px);
		border: 1px solid var(--space-arc);
		border-radius: 50%;
		opacity: 0.72;
		transform: translate(-50%, -50%);
	}

	.ring-34 { --ring-size: 89; }
	.ring-55 { --ring-size: 144; }
	.ring-89 { --ring-size: 233; }
	.ring-144 {
		--ring-size: 377;
		border-color: var(--space-arc-strong);
	}

	.fibonacci-axis {
		width: 104%;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--space-arc-strong), transparent);
		opacity: 0.46;
		transform: translate(-50%, -50%) rotate(var(--axis-angle));
	}

	.axis-horizontal { --axis-angle: 0deg; }
	.axis-vertical { --axis-angle: 90deg; }
	.axis-golden-positive { --axis-angle: 137.5deg; }
	.axis-golden-negative { --axis-angle: -137.5deg; }

	.apple-core {
		position: absolute;
		top: 50%;
		left: 50%;
		z-index: 2;
		display: block;
		width: 58px;
		height: 58px;
		color: var(--text-primary);
		text-shadow: 0 18px 36px rgba(0, 0, 0, 0.12);
		filter: drop-shadow(0 0 18px color-mix(in srgb, var(--text-primary) 16%, transparent));
		transform: translate(
			calc(-50% + (var(--cursor-x) * -0.12)),
			calc(-50% + (var(--cursor-y) * -0.12))
		);
		transition: transform 0.18s ease-out;
	}

	.hero-app-icon {
		display: block;
		z-index: 3;
		width: 100%;
		height: 100%;
		aspect-ratio: 1;
		border-radius: 22%;
		object-fit: contain;
		object-position: center;
		background: transparent;
		box-shadow: none;
		transform: translate3d(
			calc(var(--cursor-x) * var(--planet-depth)),
			calc(var(--cursor-y) * var(--planet-depth)),
			0
		) rotate(var(--planet-tilt));
		transition: filter 0.2s ease-out, transform 0.18s ease-out;
	}

	.hero-app-orbit {
		position: absolute;
		inset: 0;
		z-index: 3;
		display: block;
		pointer-events: none;
		transform-origin: 50% 50%;
		animation: planet-orbit var(--orbit-duration) linear infinite;
		animation-direction: var(--orbit-direction);
	}

	.hero-app-planet {
		position: absolute;
		top: 50%;
		left: calc(50% + var(--orbit-radius));
		display: flex;
		align-items: center;
		justify-content: center;
		width: clamp(50px, var(--planet-size), 88px);
		height: clamp(50px, var(--planet-size), 88px);
		overflow: visible;
		transform: translate(-50%, -50%) rotate(var(--orbit-start-inverse));
		animation: planet-counter-orbit var(--orbit-duration) linear infinite;
		animation-direction: var(--orbit-direction);
	}

	.app-icon-stage:hover .hero-app-icon {
		filter: saturate(1.08) contrast(1.03);
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 20px;
	}

	.social-links a {
		display: flex;
		align-items: center;
		color: var(--text-secondary);
		transition: color 0.2s ease-out, opacity 0.2s ease-out;
	}

	.social-links a:hover {
		color: var(--text-primary);
		opacity: 1;
	}

	.social-icon {
		width: 22px;
		height: 22px;
	}

	/* About */
	.about-section {
		border-top: 1px solid var(--border);
	}

	.section-title {
		font-size: clamp(36px, 5vw, 48px);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--text-primary);
		margin-bottom: 24px;
	}

	.bio {
		font-size: 17px;
		line-height: 1.7;
		color: var(--text-secondary);
		max-width: 620px;
		margin-bottom: 28px;
	}

	.skills {
		gap: 6px;
	}

	/* Projects */
	.projects-section {
		border-top: 1px solid var(--border);
	}

	/* Home nav */
	.home-nav {
		position: fixed;
		top: 20px;
		left: 24px;
		z-index: 100;
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.home-nav a {
		font-size: 14px;
		font-weight: 500;
		color: var(--text-secondary);
		padding: 8px 12px;
		border-radius: 980px;
		transition: color 0.2s ease-out, background-color 0.2s ease-out, opacity 0.2s ease-out;
	}

	.home-nav a:hover {
		color: var(--text-primary);
		background-color: var(--bg-secondary);
		opacity: 1;
	}

	.nav-sep {
		font-size: 12px;
		color: var(--text-tertiary);
		padding: 0 2px;
		user-select: none;
	}

	@keyframes app-stage-float {
		0%, 100% {
			translate: 0 0;
		}
		50% {
			translate: 0 -10px;
		}
	}

	@keyframes star-twinkle-primary {
		0%, 100% {
			opacity: 0.72;
			filter: brightness(0.92);
		}

		42% {
			opacity: 1;
			filter: brightness(1.18);
		}

		68% {
			opacity: 0.48;
			filter: brightness(0.84);
		}
	}

	@keyframes star-twinkle-secondary {
		0%, 100% {
			opacity: 0.38;
			filter: brightness(0.9);
		}

		36% {
			opacity: 0.72;
			filter: brightness(1.2);
		}

		76% {
			opacity: 0.24;
			filter: brightness(0.82);
		}
	}

	@keyframes comet-glide {
		0%, 72%, 100% {
			opacity: 0;
			filter: blur(0.2px);
			transform: rotate(var(--comet-angle)) translate3d(var(--comet-start), 0, 0) scaleX(0.72);
		}

		76% {
			opacity: 0.2;
		}

		80% {
			opacity: 0.92;
			filter: blur(0);
		}

		88% {
			opacity: 0;
			filter: blur(0.6px);
			transform: rotate(var(--comet-angle)) translate3d(var(--comet-end), 0, 0) scaleX(1);
		}
	}

	@keyframes planet-orbit {
		from {
			transform: rotate(var(--orbit-start));
		}

		to {
			transform: rotate(calc(var(--orbit-start) + 360deg));
		}
	}

	@keyframes planet-counter-orbit {
		from {
			transform: translate(-50%, -50%) rotate(var(--orbit-start-inverse));
		}

		to {
			transform: translate(-50%, -50%) rotate(calc(var(--orbit-start-inverse) - 360deg));
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.space-stars::before,
		.space-stars::after,
		.shooting-star {
			animation: none;
			filter: none;
		}

		.shooting-star {
			opacity: 0;
		}

		.app-icon-stage {
			animation: none;
			transform: none;
		}

		.hero-app-orbit {
			animation: none;
			transform: rotate(var(--orbit-start));
		}

		.hero-app-planet {
			animation: none;
			transform: translate(-50%, -50%) rotate(var(--orbit-start-inverse));
		}

		.hero-app-icon,
		.apple-core {
			transition: none;
		}
	}

	@media (max-width: 760px) {
		.hero-inner {
			grid-template-columns: 1fr;
			gap: 32px;
		}

		.hero-inner::before,
		.hero-inner::after {
			display: none;
		}

		.hero-visual {
			display: none;
		}
	}

	@media (max-width: 480px) {
		.home-nav { display: none; }

		.hero-section {
			min-height: 92svh;
		}

		.hero-inner {
			padding-top: 64px;
			padding-bottom: 64px;
		}

		.avatar {
			width: 76px;
			height: 76px;
			margin-bottom: 28px;
		}

		.hero-name {
			font-size: clamp(48px, 15vw, 64px);
		}

		.btn-primary {
			min-height: 46px;
			padding: 0 22px;
		}
	}
</style>

<script>
	const appIconStages = document.querySelectorAll<HTMLElement>(".app-icon-stage");
	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	const getRandom = (min: number, max: number) => Math.random() * (max - min) + min;

	const shuffleItems = <Item>(items: Item[]) => {
		const shuffled = [...items];

		for (let index = shuffled.length - 1; index > 0; index -= 1) {
			const swapIndex = Math.floor(Math.random() * (index + 1));
			[shuffled[index], shuffled[swapIndex]] = [shuffled[swapIndex], shuffled[index]];
		}

		return shuffled;
	};

	const organizeOrbitItems = (stage: HTMLElement) => {
		const orbitItems = Array.from(stage.querySelectorAll<HTMLElement>("[data-hero-orbit-item]"));
		const itemCount = orbitItems.length;

		if (itemCount === 0) return;

		const shuffledItems = shuffleItems(orbitItems);
		const stageWidth = stage.getBoundingClientRect().width;
		const shellCount = Math.min(4, Math.max(2, Math.ceil(itemCount / 4)));
		const minSize = stageWidth < 340 ? 48 : 52;
		const maxSize = stageWidth < 340 ? 68 : 80;
		const orbitRadii = [72, 116.5, 188.5, 44.5];
		const shellIndexes = Array.from({ length: shellCount }, () => 0);
		const shellTotals = Array.from({ length: shellCount }, (_, shell) =>
			Math.ceil((itemCount - shell) / shellCount),
		);
		const shellDurations = Array.from({ length: shellCount }, (_, shell) => getRandom(38, 46) + shell * 17);
		const shellDirections = Array.from({ length: shellCount }, (_, shell) =>
			shell % 2 === 0 ? "normal" : "reverse",
		);

		shuffledItems.forEach((orbitItem, shuffledIndex) => {
			const shell = shuffledIndex % shellCount;
			const positionInShell = shellIndexes[shell];
			shellIndexes[shell] += 1;

			const totalInShell = Math.max(shellTotals[shell], 1);
			const segment = 360 / totalInShell;
			const jitter = Math.min(18, segment * 0.28);
			const angle = positionInShell * segment + shell * 72 + getRandom(-jitter, jitter);
			const size = getRandom(minSize, maxSize);
			const radius = orbitRadii[shell] ?? orbitRadii[orbitRadii.length - 1];
			const duration = shellDurations[shell];
			const depth = getRandom(-0.34, 0.58);
			const tilt = getRandom(-7, 7);
			const direction = shellDirections[shell];

			orbitItem.style.setProperty("--orbit-start", `${angle.toFixed(2)}deg`);
			orbitItem.style.setProperty("--orbit-start-inverse", `${(-angle).toFixed(2)}deg`);
			orbitItem.style.setProperty("--orbit-radius", `${radius.toFixed(2)}px`);
			orbitItem.style.setProperty("--orbit-duration", `${duration.toFixed(2)}s`);
			orbitItem.style.setProperty("--orbit-direction", direction);
			orbitItem.style.setProperty("--planet-size", `${size.toFixed(2)}px`);
			orbitItem.style.setProperty("--planet-depth", depth.toFixed(2));
			orbitItem.style.setProperty("--planet-tilt", `${tilt.toFixed(2)}deg`);
			orbitItem.style.zIndex = String(4 + shell);
		});
	};

	appIconStages.forEach((stage) => {
		organizeOrbitItems(stage);

		if (!prefersReducedMotion) {
			const resetStage = () => {
				stage.style.setProperty("--cursor-x", "0px");
				stage.style.setProperty("--cursor-y", "0px");
				stage.style.setProperty("--stage-tilt-x", "0deg");
				stage.style.setProperty("--stage-tilt-y", "0deg");
			};

			stage.addEventListener("pointermove", (event) => {
				const rect = stage.getBoundingClientRect();
				const x = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
				const y = ((event.clientY - rect.top) / rect.height - 0.5) * 2;

				stage.style.setProperty("--cursor-x", `${(x * 18).toFixed(2)}px`);
				stage.style.setProperty("--cursor-y", `${(y * 18).toFixed(2)}px`);
				stage.style.setProperty("--stage-tilt-x", `${(x * 4).toFixed(2)}deg`);
				stage.style.setProperty("--stage-tilt-y", `${(y * -4).toFixed(2)}deg`);
			});

			stage.addEventListener("pointerleave", resetStage);
		}
	});
</script>
